# ============================================
# Astro-Theme-Aither Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Google Analytics (leave empty to disable)
PUBLIC_GA_ID=

# Crisp Chat (leave empty to disable)
PUBLIC_CRISP_WEBSITE_ID=

# Giscus Comments (leave all empty to disable)
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# ============================================
# Deploy — set these as GitHub Secrets, NOT in .env
# ============================================
# Cloudflare Pages (set as GitHub Secrets)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

