---
/**
 * Pin icon — Geist Design System style.
 * viewBox: 0 0 16 16, stroke-based, 16×16 native size.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 16 16"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  shape-rendering="geometricPrecision"
  class={className}
>
  <path d="M9.5 1.5L14.5 6.5L10 11L9 14L2 7L5 6Z" />
  <path d="M5 6L10 11" />
  <path d="M1.5 14.5L5.5 10.5" />
</svg>
