---
/**
 * Prose wrapper for Markdown content.
 * Uses CSS variables for theme-aware typography.
 * All values are customizable per theme via --heading-*, --blockquote-*, etc.
 */
import 'katex/dist/katex.min.css';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['prose-content prose prose-neutral dark:prose-invert max-w-none', className]}>
  <slot />
</div>

<style is:global>
  /* Use double class for higher specificity than Tailwind prose */
  .prose-content.prose-content {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: var(--line-height-body);
    letter-spacing: -0.022em;
    color: var(--foreground);
  }

  /* Headings — per-level color, font, decoration */
  .prose-content.prose h1 {
    font-family: var(--font-heading);
    color: var(--heading-h1-color);
    letter-spacing: var(--letter-spacing-h1);
    font-variant: var(--heading-h1-font-variant);
    border-bottom: var(--heading-h1-border);
  }

  .prose-content.prose h2 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 2em;
    margin-bottom: 1em;
    color: var(--heading-h2-color);
    border-bottom: var(--heading-h2-border);
  }

  .prose-content.prose h3 {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 1.5em;
    margin-bottom: 0.8em;
    color: var(--heading-h3-color);
  }

  .prose-content.prose h4 {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 1.2em;
    margin-bottom: 0.6em;
    color: var(--heading-h4-color);
  }

  /* Strong — theme-aware highlight */
  .prose-content.prose strong {
    color: var(--strong-color);
    background-color: var(--strong-bg);
    border-radius: 3px;
  }

  /* Em — theme-aware color */
  .prose-content.prose em {
    color: var(--em-color);
  }

  /* Links — theme color */
  .prose-content.prose a {
    color: var(--color-link);
    text-decoration: none;
  }

  .prose-content.prose a:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  /* Paragraphs */
  .prose-content.prose p {
    margin-top: var(--paragraph-spacing);
    margin-bottom: var(--paragraph-spacing);
  }

  /* Lists */
  .prose-content.prose li {
    margin-top: 0.25em;
    margin-bottom: 0.25em;
  }

  /* Blockquote — fully theme-aware */
  .prose-content.prose blockquote {
    font-style: var(--blockquote-font-style);
    border-left: 3px solid var(--blockquote-border-color);
    background-color: var(--blockquote-bg);
    border-radius: var(--blockquote-border-radius);
    color: var(--blockquote-text-color);
  }

  .prose-content.prose blockquote p::before,
  .prose-content.prose blockquote p::after {
    content: none;
  }

  /* Code blocks — theme-aware */
  .prose-content.prose pre {
    background: var(--pre-bg);
    color: var(--foreground);
    border-radius: var(--pre-border-radius);
    font-family: var(--font-code);
    font-size: 14px;
    line-height: 1.6;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }

  /* Inline code */
  .prose-content.prose code {
    background: var(--code-bg);
    color: var(--code-color);
    padding: 2px 6px;
    border-radius: var(--code-border-radius);
    font-family: var(--font-code);
    font-size: 0.9em;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .prose-content.prose code::before,
  .prose-content.prose code::after {
    content: none;
  }

  .prose-content.prose pre code {
    background: none;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose-content.prose .expressive-code {
    margin: 1.6em 0;
  }

  .prose-content.prose .expressive-code .frame {
    border-radius: var(--pre-border-radius);
  }

  .prose-content.prose .expressive-code .copy {
    opacity: 1;
  }

  .prose-content.prose .katex {
    color: var(--foreground);
  }

  .prose-content.prose .katex-display {
    margin: 1.5em 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.25rem;
  }

  .prose-content.prose .katex-display > .katex {
    display: inline-block;
    min-width: min-content;
  }

  .prose-content.prose .aither-markmap {
    margin: 1.75em 0;
    border: 1px solid var(--border);
    border-radius: var(--pre-border-radius);
    background: color-mix(in srgb, var(--pre-bg) 92%, transparent);
    padding: 1rem;
    overflow: auto hidden;
  }

  .prose-content.prose .aither-markmap__svg {
    display: block;
    width: 100%;
    min-height: 22rem;
  }

  .prose-content.prose .aither-markmap__svg text {
    fill: var(--foreground);
    font-family: var(--font-body);
  }

  .prose-content.prose .aither-markmap__svg circle {
    fill: var(--color-link);
  }

  .prose-content.prose .aither-markmap__svg line,
  .prose-content.prose .aither-markmap__svg path {
    stroke: color-mix(in srgb, var(--foreground) 55%, transparent);
  }

  .prose-content.prose svg[id^='mermaid-'] {
    display: block;
    width: 100%;
    height: auto;
    margin: 1.75em 0;
    border: 1px solid var(--border);
    border-radius: var(--pre-border-radius);
    background: color-mix(in srgb, var(--pre-bg) 92%, transparent);
    padding: 1rem;
  }

  /* HR */
  .prose-content.prose hr {
    border-color: var(--border);
  }

  /* Images — theme-aware border-radius */
  .prose-content.prose img {
    border-radius: var(--image-border-radius);
    height: auto;
    max-width: 100%;
  }

  /* Figure captions */
  .prose-content.prose figure {
    margin: 1.5em 0;
  }

  .prose-content.prose figcaption {
    text-align: center;
    font-size: 0.875em;
    color: var(--muted-foreground);
    margin-top: 0.5em;
  }

  /* Tables — prevent overflow on mobile */
  .prose-content.prose table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }

  /* General overflow prevention */
  .prose-content.prose-content {
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
</style>

<script>
  import { bootstrapRootInit } from '@/lib/dom-init';
  import { THEME_CHANGE_EVENT } from '@/lib/theme';

  const MARKMAP_STYLE_ID = 'aither-markmap-global-style';

  const decodeDiagramSource = (encoded: string) => {
    try {
      return atob(encoded);
    } catch {
      return '';
    }
  };

  const ensureMarkmapStyles = (css: string) => {
    if (document.getElementById(MARKMAP_STYLE_ID)) return;

    const style = document.createElement('style');
    style.id = MARKMAP_STYLE_ID;
    style.textContent = css;
    document.head.append(style);
  };

  bootstrapRootInit('prose-markmap', '.prose-content', (root, signal) => {
    const containers = Array.from(root.querySelectorAll<HTMLElement>('[data-markmap-source]'));
    if (containers.length === 0) return;

    void (async () => {
      const [{ Transformer }, { Markmap, globalCSS }] = await Promise.all([
        import('markmap-lib'),
        import('markmap-view'),
      ]);

      if (signal.aborted) return;

      ensureMarkmapStyles(globalCSS);

      const transformer = new Transformer();
      const instances: Array<{ map: InstanceType<typeof Markmap>; svg: SVGElement }> = [];

      const buildOptions = () => {
        const styles = getComputedStyle(document.documentElement);
        const accent = styles.getPropertyValue('--color-link').trim() || '#0a66ff';
        const foreground = styles.getPropertyValue('--foreground').trim() || '#111111';
        const line = styles.getPropertyValue('--border').trim() || foreground;

        return {
          autoFit: true,
          fitRatio: 0.95,
          initialExpandLevel: 2,
          maxWidth: 320,
          duration: 240,
          color: () => accent,
          style: (id: string) => `
            #${id} .markmap-link { stroke: ${line}; }
            #${id} .markmap-node > circle { fill: ${accent}; }
            #${id} .markmap-node > text {
              fill: ${foreground};
              font-family: var(--font-body);
            }
          `,
        };
      };

      const applyTheme = () => {
        const nextOptions = buildOptions();
        void Promise.all(
          instances.map(async ({ map }) => {
            map.setOptions(nextOptions);
            await map.fit();
          }),
        );
      };

      for (const container of containers) {
        const encodedSource = container.dataset.markmapSource;
        if (!encodedSource) continue;

        const source = decodeDiagramSource(encodedSource);
        if (!source) continue;

        const svg = container.querySelector<SVGElement>('svg');
        if (!svg) continue;

        const { root: data } = transformer.transform(source);
        const map = Markmap.create(svg, buildOptions(), data);
        instances.push({ map, svg });
      }

      if (instances.length === 0) return;

      const handleResize = () => {
        void Promise.all(instances.map(({ map }) => map.fit()));
      };

      window.addEventListener('resize', handleResize, { passive: true, signal });
      window.addEventListener(THEME_CHANGE_EVENT, applyTheme, { signal });

      signal.addEventListener(
        'abort',
        () => {
          instances.forEach(({ map }) => map.destroy());
        },
        { once: true },
      );
    })();
  });
</script>
