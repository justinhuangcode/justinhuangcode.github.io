---
/**
 * Prose wrapper for Markdown content.
 * Uses CSS variables for theme-aware typography.
 * All values are customizable per theme via --heading-*, --blockquote-*, etc.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['prose-content prose prose-neutral dark:prose-invert max-w-none', className]}>
  <slot />
</div>

<style is:global>
  /* Use double class for higher specificity than Tailwind prose */
  .prose-content.prose-content {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: var(--line-height-body);
    letter-spacing: -0.022em;
    color: var(--foreground);
  }

  /* Headings — per-level color, font, decoration */
  .prose-content.prose h1 {
    font-family: var(--font-heading);
    color: var(--heading-h1-color);
    letter-spacing: var(--letter-spacing-h1);
    font-variant: var(--heading-h1-font-variant);
    border-bottom: var(--heading-h1-border);
  }

  .prose-content.prose h2 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 2em;
    margin-bottom: 1em;
    color: var(--heading-h2-color);
    border-bottom: var(--heading-h2-border);
  }

  .prose-content.prose h3 {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 1.5em;
    margin-bottom: 0.8em;
    color: var(--heading-h3-color);
  }

  .prose-content.prose h4 {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 1.2em;
    margin-bottom: 0.6em;
    color: var(--heading-h4-color);
  }

  /* Strong — theme-aware highlight */
  .prose-content.prose strong {
    color: var(--strong-color);
    background-color: var(--strong-bg);
    border-radius: 3px;
  }

  /* Em — theme-aware color */
  .prose-content.prose em {
    color: var(--em-color);
  }

  /* Links — theme color */
  .prose-content.prose a {
    color: var(--color-link);
    text-decoration: none;
  }

  .prose-content.prose a:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  /* Paragraphs */
  .prose-content.prose p {
    margin-top: var(--paragraph-spacing);
    margin-bottom: var(--paragraph-spacing);
  }

  /* Lists */
  .prose-content.prose li {
    margin-top: 0.25em;
    margin-bottom: 0.25em;
  }

  /* Blockquote — fully theme-aware */
  .prose-content.prose blockquote {
    font-style: var(--blockquote-font-style);
    border-left: 3px solid var(--blockquote-border-color);
    background-color: var(--blockquote-bg);
    border-radius: var(--blockquote-border-radius);
    color: var(--blockquote-text-color);
  }

  .prose-content.prose blockquote p::before,
  .prose-content.prose blockquote p::after {
    content: none;
  }

  /* Code blocks — theme-aware */
  .prose-content.prose pre {
    background: var(--pre-bg);
    color: var(--foreground);
    border-radius: var(--pre-border-radius);
    font-family: var(--font-code);
    font-size: 14px;
    line-height: 1.6;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }

  /* Inline code */
  .prose-content.prose code {
    background: var(--code-bg);
    color: var(--code-color);
    padding: 2px 6px;
    border-radius: var(--code-border-radius);
    font-family: var(--font-code);
    font-size: 0.9em;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .prose-content.prose code::before,
  .prose-content.prose code::after {
    content: none;
  }

  .prose-content.prose pre code {
    background: none;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  /* HR */
  .prose-content.prose hr {
    border-color: var(--border);
  }

  /* Images — theme-aware border-radius */
  .prose-content.prose img {
    border-radius: var(--image-border-radius);
    height: auto;
    max-width: 100%;
  }

  /* Figure captions */
  .prose-content.prose figure {
    margin: 1.5em 0;
  }

  .prose-content.prose figcaption {
    text-align: center;
    font-size: 0.875em;
    color: var(--muted-foreground);
    margin-top: 0.5em;
  }

  /* Tables — prevent overflow on mobile */
  .prose-content.prose table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }

  /* General overflow prevention */
  .prose-content.prose-content {
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
</style>
