---
/**
 * Prose wrapper for Markdown content.
 * Uses @tailwindcss/typography as base, with scoped CSS overrides
 * for theme-specific styling (Tailwind v4 prose modifiers have
 * insufficient specificity for some properties).
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['prose-content prose prose-neutral dark:prose-invert max-w-none', className]}>
  <slot />
</div>

<style>
  .prose-content {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.47;
    letter-spacing: -0.022em;
    color: var(--foreground);
  }

  /* Headings — system font, semibold */
  .prose-content :global(h2) {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 2em;
    margin-bottom: 1em;
  }

  .prose-content :global(h3) {
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 1.5em;
    margin-bottom: 0.8em;
  }

  .prose-content :global(h4) {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 1.2em;
    margin-bottom: 0.6em;
  }

  /* Links — theme color */
  .prose-content :global(a) {
    color: var(--color-link);
    text-decoration: none;
  }

  .prose-content :global(a:hover) {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  /* Lists */
  .prose-content :global(li) {
    margin-top: 0.25em;
    margin-bottom: 0.25em;
  }

  /* Blockquote — no italic, no quotes */
  .prose-content :global(blockquote) {
    font-style: normal;
    border-left: 3px solid var(--border);
    color: var(--muted-foreground);
  }

  .prose-content :global(blockquote p::before),
  .prose-content :global(blockquote p::after) {
    content: none;
  }

  /* Code blocks */
  .prose-content :global(pre) {
    background: var(--muted);
    color: var(--foreground);
    border-radius: 0;
    font-size: 14px;
    line-height: 1.6;
  }

  /* Inline code — no backtick quotes */
  .prose-content :global(code) {
    background: var(--muted);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose-content :global(code::before),
  .prose-content :global(code::after) {
    content: none;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  /* HR */
  .prose-content :global(hr) {
    border-color: var(--border);
  }

  /* Images — optimized display */
  .prose-content :global(img) {
    border-radius: 0.375rem;
    height: auto;
    max-width: 100%;
  }

  /* Figure captions for ![alt](src) with title */
  .prose-content :global(figure) {
    margin: 1.5em 0;
  }

  .prose-content :global(figcaption) {
    text-align: center;
    font-size: 0.875em;
    color: var(--muted-foreground);
    margin-top: 0.5em;
  }
</style>
