---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ModeSwitcher from './ModeSwitcher.astro';
import NavbarMobile from './NavbarMobile.astro';
import { siteConfig } from '@/config/site';
import { getLocalizedThemeLabels } from '@/config/themes';
import {
  getMessages,
  getLocalizedPath,
  translateNav,
  type Locale,
} from '@/i18n';
import { isActiveNavPath } from '@/lib/navigation';

interface Props {
  locale: Locale;
}

interface ResolvedNavLink {
  title: string;
  href: string;
  isActive: boolean;
}

const { locale } = Astro.props;
const m = getMessages(locale);
const themeLabels = getLocalizedThemeLabels(locale);
const currentPath = Astro.url.pathname;
const showModeSwitch = siteConfig.ui.enableModeSwitch;
const showMoreThemes = siteConfig.ui.showMoreThemesMenu;

// Merge static nav items with auto-generated section nav items
const sectionNavItems = siteConfig.sections.map((s) => ({
  labelKey: s.labelKey,
  href: `/${s.id}`,
}));
// Insert section items right after the primary reading entry (Blog)
const primaryNavItem = siteConfig.nav.slice(0, 1);
const trailingNavItems = siteConfig.nav.slice(1);
const allNavItems = [
  ...primaryNavItem,
  ...sectionNavItems,
  ...trailingNavItems,
];
const resolvedNavLinks: ResolvedNavLink[] = allNavItems.map((item) => {
  const href = getLocalizedPath(item.href, locale);

  return {
    title: translateNav(item.labelKey, locale),
    href,
    isActive: isActiveNavPath(currentPath, href, {
      matchDescendants: item.href !== '/',
      descendants: item.href === '/' ? ['posts', 'page'] : [],
    }),
  };
});
---

<header
  class="site-nav fixed inset-x-0 top-0 z-40 min-h-[58px] border-b border-[var(--color-nav-border)]"
>
  <div class="mx-auto px-4 lg:px-0">
    <nav
      aria-label="Main navigation"
      class="hidden lg:flex lg:items-center lg:justify-between lg:pl-[16px] lg:pr-[32px]"
    >
      <a
        href={getLocalizedPath('/', locale)}
        aria-label="Home"
        class="site-brand text-[18px] font-semibold leading-5 py-[19px] pr-[18px] lg:pl-[16px] text-[var(--color-nav-text-active)] hover:text-[var(--color-nav-text-hover)]"
      >
        <span class="flex items-center gap-2"><span aria-hidden="true">✍️</span><span>{siteConfig.name}</span></span>
      </a>

      <div class="flex items-center">
        <ul class="flex list-none">
          {
            resolvedNavLinks.map((item) => {
              return (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'nav-item block text-[15px] leading-5 px-[14px] py-[19px] hover:text-[var(--color-text)] hover:no-underline',
                      item.isActive
                        ? 'nav-link-active font-semibold text-[var(--color-nav-text-active)]'
                        : 'text-[var(--color-nav-text)]',
                    ]}
                    data-text={item.title}
                  >
                    <span class="col-start-1 row-start-1">{item.title}</span>
                  </a>
                </li>
              );
            })
          }
        </ul>

        <div class="flex items-center gap-1 ml-2">
          {showModeSwitch && (
            <ModeSwitcher
              labels={m.common.mode}
              themeLabels={themeLabels}
              defaultMode={siteConfig.ui.defaultMode}
              defaultStyle={siteConfig.ui.defaultStyle}
              showMoreThemes={showMoreThemes}
            />
          )}
          <LanguageSwitcher currentLocale={locale} currentPath={currentPath} />
        </div>
      </div>
    </nav>

    <NavbarMobile
      locale={locale}
      currentPath={currentPath}
      siteName={siteConfig.name}
      navLinks={resolvedNavLinks}
      languageLabel={m.common.language}
      modeLabels={m.common.mode}
      themeLabels={themeLabels}
      showThemeControls={showModeSwitch}
      showMoreThemes={showMoreThemes}
      defaultMode={siteConfig.ui.defaultMode}
      defaultStyle={siteConfig.ui.defaultStyle}
    />
  </div>
</header>

<div class="h-[58px]" aria-hidden="true" data-navbar-spacer></div>
