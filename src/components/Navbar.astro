---
import Container from './Container.astro';
import Logo from './Logo.astro';
import { siteConfig } from '@/config/site';
import { getMessages, getLocalizedPath, type Locale } from '@/i18n';
import ModeSwitcher from '@/components/react/ModeSwitcher';
import LanguageSwitcher from '@/components/react/LanguageSwitcher';
import NavbarMobile from '@/components/react/NavbarMobile';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = getMessages(locale);
const currentPath = Astro.url.pathname;
---

<header
  class="site-nav fixed inset-x-0 top-0 z-40 min-h-[50px] border-b border-[var(--color-nav-border)]"
>
  <Container class="px-4">
    <nav
      aria-label="Main navigation"
      class="hidden lg:flex lg:items-center lg:justify-between"
    >
      <a
        href="/"
        aria-label="Home"
        class="text-[18px] font-semibold leading-5 py-[15px] pr-[15px] text-[var(--color-nav-text-active)] hover:text-[var(--color-nav-text-hover)]"
      >
        <span class="flex items-center gap-2"><span aria-hidden="true">✍️</span><span>{siteConfig.name}</span></span>
      </a>

      <div class="flex items-center">
        <ul class="flex list-none">
          {
            siteConfig.nav.map((item) => {
              const href = getLocalizedPath(item.href, locale);
              const cleanCurrent = currentPath.replace(/\/$/, '') || '/';
              const cleanHref = href.replace(/\/$/, '') || '/';
              const isActive = cleanCurrent === cleanHref;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      'block text-sm leading-5 p-[15px] hover:text-[var(--color-text)] hover:no-underline',
                      isActive
                        ? 'nav-link-active font-semibold text-[var(--color-nav-text-active)]'
                        : 'text-[var(--color-nav-text)]',
                    ]}
                  >
                    {m.nav[item.labelKey]}
                  </a>
                </li>
              );
            })
          }
        </ul>

        <div class="flex items-center gap-1 ml-2">
          <ModeSwitcher client:idle />
          <LanguageSwitcher client:idle currentLocale={locale} currentPath={currentPath} />
        </div>
      </div>
    </nav>

    <NavbarMobile
      client:idle
      locale={locale}
      currentPath={currentPath}
      siteName={siteConfig.name}
      logoLight={siteConfig.images.logoLight}
      logoDark={siteConfig.images.logoDark}
      navLinks={siteConfig.nav.map((item) => ({ title: m.nav[item.labelKey], href: getLocalizedPath(item.href, locale) }))}
      languageLabel={m.common.language}
    />
  </Container>
</header>

<div class="h-[50px]" aria-hidden="true" data-navbar-spacer></div>
