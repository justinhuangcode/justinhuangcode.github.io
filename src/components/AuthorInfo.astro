---
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { IconUser } from '@/components/icons';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const { name, avatar } = siteConfig.author;
---

<div class:list={['flex items-center gap-2', className]}>
  {avatar ? (
    typeof avatar === 'string' ? (
      <img
        src={avatar}
        alt={name}
        width={24}
        height={24}
        class="size-6 rounded-full object-cover"
      />
    ) : (
      <Image
        src={avatar}
        alt={name}
        width={24}
        height={24}
        class="size-6 rounded-full object-cover"
      />
    )
  ) : (
    <div class="size-6 rounded-full bg-muted flex items-center justify-center text-muted-foreground">
      <IconUser className="size-3.5" />
    </div>
  )}
  <span class="text-sm font-mono text-muted-foreground">{name}</span>
</div>
