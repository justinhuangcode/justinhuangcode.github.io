---
import SocialIcon from '@/components/icons/SocialIcon.astro';
import Container from './Container.astro';
import BuiltWithButton from './BuiltWithButton.astro';
import { siteConfig, type FooterSection, type SocialLink } from '@/config/site';
import {
  getMessages,
  getLocalizedPath,
  translateNav,
  type Locale,
} from '@/i18n';
import { isActiveNavPath } from '@/lib/navigation';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = getMessages(locale);
const currentPath = Astro.url.pathname;
const footerSections: FooterSection[] = siteConfig.footer.sections;

function resolveInternalHref(href: string): string {
  if (href.startsWith('#')) return href;
  return getLocalizedPath(href, locale);
}

function resolveSocialHref(href: string): string {
  if (/^https?:\/\//.test(href) || href.startsWith('#')) return href;
  return resolveInternalHref(href);
}

function isConfiguredSocialLink(link: SocialLink): boolean {
  const href = link.href.trim();
  return href !== '' && href !== '#';
}

function isActive(href: string): boolean {
  if (href.includes('#') || /^https?:\/\//.test(href)) return false;
  return isActiveNavPath(currentPath, resolveInternalHref(href), {
    matchDescendants: href !== '/',
    descendants: href === '/' ? ['posts', 'page'] : [],
  });
}

const footerSectionTitles = [m.footer.navigate, m.footer.subscribe, m.footer.source];
const socialLinks = siteConfig.social.filter(isConfiguredSocialLink);
---

<footer class="site-footer border-t font-body">
  <Container class="px-4">
    <div class="site-footer-main grid grid-cols-2 gap-6 py-6 md:grid-cols-6">
      <div class="col-span-full flex flex-col items-start md:col-span-2">
        <div class="flex items-center gap-2">
          <span aria-hidden="true">✍️</span>
          <span class="site-footer-brand text-[18px] font-semibold">{siteConfig.name}</span>
        </div>
        <p class="site-footer-tagline font-body text-muted-foreground text-base py-2 md:pr-12">
          {m.footer.tagline}
        </p>
        {
          socialLinks.length > 0 && (
            <nav aria-label="Social links" class="flex items-center gap-4 pt-3">
              {
                socialLinks.map((link) => (
                  <a
                    href={resolveSocialHref(link.href)}
                    target={/^https?:\/\//.test(link.href) ? '_blank' : undefined}
                    rel={/^https?:\/\//.test(link.href) ? 'noreferrer' : undefined}
                    aria-label={link.title}
                    class="site-footer-social-link inline-flex size-8 items-center justify-center rounded-full border border-border text-foreground hover:bg-primary/10 hover:text-primary hover:border-primary/30 transition-all duration-200"
                  >
                    <SocialIcon name={link.icon} class="size-4" />
                  </a>
                ))
              }
            </nav>
          )
        }
      </div>

      {
        footerSections.map((section, i) => (
          <div class:list={["col-span-1 md:col-span-1 flex flex-col items-start", i === 0 && "md:col-start-4"]}>
            <span class="site-footer-heading text-sm font-semibold uppercase">{footerSectionTitles[i]}</span>
            <ul class="mt-2 list-inside space-y-2">
              {section.items.map((item) => (
                <li>
                  <a
                    href={item.external ? item.href : resolveInternalHref(item.href)}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noopener noreferrer' : undefined}
                    class:list={[
                      "site-footer-link text-sm transition-colors duration-150 hover:text-[var(--color-link)] focus-visible:text-[var(--color-link)]",
                      isActive(item.href)
                        ? "font-semibold text-primary"
                        : "text-muted-foreground",
                    ]}
                  >
                    {item.labelKey ? translateNav(item.labelKey, locale) : item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>

  <div class="site-footer-bottom py-12">
    <Container
      class="px-4 flex flex-col items-center justify-between gap-4 text-center sm:flex-row sm:text-left"
    >
      <span class="text-muted-foreground text-sm">
        &copy; {siteConfig.footer.copyrightYear === 'auto' ? new Date().getFullYear() : siteConfig.footer.copyrightYear}
        {siteConfig.name}. {m.footer.rightsReserved}
      </span>
	      <nav class="flex flex-wrap items-center justify-center gap-3 font-mono text-xs text-muted-foreground sm:justify-start">
	        <a href="/protocol.json" class="site-footer-aux-link hover:text-[var(--color-link)] transition-colors py-2 px-1">protocol.json</a>
	        <a href="/skill.md" class="site-footer-aux-link hover:text-[var(--color-link)] transition-colors py-2 px-1">skill.md</a>
	        <a href={resolveInternalHref('/llms.txt')} class="site-footer-aux-link hover:text-[var(--color-link)] transition-colors py-2 px-1">llms.txt</a>
      </nav>
      <BuiltWithButton locale={locale} />
    </Container>
  </div>
</footer>
