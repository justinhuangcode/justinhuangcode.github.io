---
/**
 * Crisp Chat — auto-enabled when siteConfig.crisp.websiteId is set.
 * Renders nothing when the ID is empty.
 */
import { siteConfig } from '@/config/site';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const crispId = siteConfig.crisp.websiteId;
const crispLocaleMap: Record<Locale, string> = {
  en: 'en',
  'zh-hans': 'zh',
  'zh-hant': 'zh',
  ko: 'ko',
};
const crispLocale = crispLocaleMap[locale];
---

{crispId && (
  <script is:inline define:vars={{ crispId, crispLocale }}>
    window.CRISP_RUNTIME_CONFIG = {
      locale: crispLocale,
    };
    window.$crisp = [];
    window.CRISP_WEBSITE_ID = crispId;
    (function () {
      var d = document;
      var s = d.createElement('script');
      s.src = 'https://client.crisp.chat/l.js';
      s.async = 1;
      d.getElementsByTagName('head')[0].appendChild(s);
    })();
  </script>
)}
