---
import { formatDate } from '@/lib/formatter';

interface Props {
  slug: string;
  title: string;
  date: Date;
  description?: string;
  descriptionPrefix?: string;
  sourcePublication?: string;
  basePath?: string;
  section?: string;
  titleLang?: string;
  descriptionLang?: string;
}

const {
  slug,
  title,
  date,
  description,
  descriptionPrefix,
  sourcePublication,
  basePath = '',
  section = 'recommendations',
  titleLang,
  descriptionLang,
} = Astro.props;
---

<li class="recommendations-card border-b border-border last:border-b-0">
  <a href={`${basePath}/${section}/${slug}`} class="recommendations-card-link block px-5 py-5 sm:px-6 sm:py-6 hover:bg-[var(--color-bg-hover)]">
    <div class="recommendations-card-meta">
      <span>{formatDate(date)}</span>
      {sourcePublication && (
        <Fragment>
          <span aria-hidden="true">&middot;</span>
          <span>{sourcePublication}</span>
        </Fragment>
      )}
    </div>
    <h3 lang={titleLang} class="recommendations-card-title">
      {title}
    </h3>
    {
      description && (
        <p lang={descriptionLang} class="recommendations-card-note">
          {descriptionPrefix && <span class="recommendations-card-note-prefix">【{descriptionPrefix}】</span>}
          {description}
        </p>
      )
    }
  </a>
</li>

<style>
  .recommendations-card-link {
    text-decoration: none;
  }

  .recommendations-card-meta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    color: color-mix(in srgb, var(--muted-foreground) 86%, transparent);
    font-family: var(--font-code);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .recommendations-card-title {
    margin: 0.7rem 0 0;
    color: var(--foreground);
    font-family: var(--font-serif);
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1.42;
  }

  .recommendations-card-link:hover .recommendations-card-title {
    color: var(--color-link-hover);
  }

  .recommendations-card-note {
    margin: 0.55rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .recommendations-card-note-prefix {
    color: var(--foreground);
    margin-right: 0.1em;
  }
</style>
