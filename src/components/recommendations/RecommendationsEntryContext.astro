---
import { getRecommendationsUiCopy } from '@/lib/recommendations-ui';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
  sourceTitle?: string;
  sourcePublication?: string;
  sourceLanguage?: string;
  sourceUrl?: string;
}

const {
  locale,
  sourceTitle,
  sourcePublication,
  sourceLanguage,
  sourceUrl,
} = Astro.props;
const copy = getRecommendationsUiCopy(locale);
---

<section class="recommendations-entry-context" aria-label={copy.detailEyebrow}>
  <p class="recommendations-entry-kicker">{copy.detailEyebrow}</p>
  <div class="recommendations-entry-hero">
    <div class="recommendations-entry-origin">
      {
        sourceTitle && (
          <Fragment>
            <p class="recommendations-entry-origin-label">{copy.sourceTitleLabel}</p>
            <p class="recommendations-entry-origin-title">{sourceTitle}</p>
          </Fragment>
        )
      }
    </div>
    {
      sourceUrl && (
        <a class="recommendations-entry-primary-link" href={sourceUrl} target="_blank" rel="noreferrer">
          <span>{copy.sourceLinkAction}</span>
          <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </div>
  <dl class="recommendations-entry-facts">
    {
      sourcePublication && (
        <div class="recommendations-entry-fact">
          <dt>{copy.sourcePublicationLabel}</dt>
          <dd>{sourcePublication}</dd>
        </div>
      )
    }
    {
      sourceLanguage && (
        <div class="recommendations-entry-fact">
          <dt>{copy.sourceLanguageLabel}</dt>
          <dd>{sourceLanguage}</dd>
        </div>
      )
    }
  </dl>
</section>

<style>
  .recommendations-entry-context {
    margin: 0 0 1.15rem;
    padding: 1rem 1.05rem 1.08rem;
    border: 1px solid color-mix(in srgb, var(--border) 92%, transparent);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--background) 98%, white 2%), var(--background));
  }

  .recommendations-entry-kicker {
    margin: 0;
    color: color-mix(in srgb, var(--muted-foreground) 84%, transparent);
    font-family: var(--font-code);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .recommendations-entry-hero {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.72rem;
  }

  .recommendations-entry-origin-label {
    margin: 0;
    color: color-mix(in srgb, var(--muted-foreground) 88%, transparent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .recommendations-entry-origin-title {
    margin: 0.28rem 0 0;
    color: var(--foreground);
    font-family: var(--font-serif);
    font-size: 1.16rem;
    font-weight: 600;
    line-height: 1.42;
  }

  .recommendations-entry-primary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    width: fit-content;
    color: var(--color-link);
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-link) 22%, transparent);
  }

  .recommendations-entry-primary-link:hover {
    color: var(--color-link-hover);
    border-bottom-color: color-mix(in srgb, var(--color-link-hover) 40%, transparent);
  }

  .recommendations-entry-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 0.85rem 1rem;
    margin: 0.95rem 0 0;
    padding-top: 0.9rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 88%, transparent);
  }

  .recommendations-entry-fact dt {
    margin: 0;
    color: color-mix(in srgb, var(--muted-foreground) 86%, transparent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .recommendations-entry-fact dd {
    margin: 0.28rem 0 0;
    color: var(--foreground);
    font-size: 0.98rem;
    font-weight: 500;
    line-height: 1.45;
    word-break: break-word;
  }

  @media (min-width: 768px) {
    .recommendations-entry-context {
      padding: 1.05rem 1.15rem 1.15rem;
    }

    .recommendations-entry-hero {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.2rem;
    }

    .recommendations-entry-primary-link {
      margin-top: 0.1rem;
      flex-shrink: 0;
    }
  }
</style>
