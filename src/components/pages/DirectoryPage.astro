---
import DirectoryLayout from '@/layouts/DirectoryLayout.astro';
import DirectorySearch from '@/components/directory/DirectorySearch.astro';
import DirectoryTransparency from '@/components/directory/DirectoryTransparency.astro';
import { siteConfig } from '@/config/site';
import { getLocalizedPath, type Locale } from '@/i18n';
import { getDirectoryContent } from '@/lib/directory';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getDirectoryContent(locale);
const directoryHref = getLocalizedPath('/directory', locale);
const visibleGroups = content.groups.filter(
  (group) => group.annotations.show_in_directory === 'true' && group.links.length > 0,
);
const emptyCopy =
  locale === 'zh-hant'
    ? {
        title: '導航內容準備中',
        description: '目錄頁已經啟用，但目前還沒有站點自己的導航條目。後續把資料補到 src/data/directory-links.ts 即可自動出現在這裡。',
      }
    : locale === 'zh-hans'
      ? {
          title: '导航内容准备中',
          description: '目录页已经启用，但目前还没有站点自己的导航条目。后续把资料补到 src/data/directory-links.ts 即可自动出现在这里。',
        }
      : locale === 'ko'
        ? {
            title: '디렉토리 준비 중',
            description: '디렉토리 페이지는 이미 활성화되었지만 아직 사이트 전용 링크 데이터가 없습니다. 이후 src/data/directory-links.ts 에 항목을 추가하면 여기에서 자동으로 노출됩니다.',
          }
        : {
            title: 'Directory content is coming soon',
            description: 'The directory surface is enabled, but this site has not added its own link inventory yet. Add entries in src/data/directory-links.ts and they will appear here automatically.',
          };
---

<DirectoryLayout
  pageTitle={content.pageTitle}
  description={siteConfig.description}
  backgroundColor={content.backgroundColor}
  directoryHref={directoryHref}
  siteTitle={content.siteTitle}
  footerThemeAttribution={content.footerThemeAttribution}
  footerThemeUrl={content.footerThemeUrl}
  footerIcp={content.footerIcp}
  footerIcp2={content.footerIcp2}
  postchatEnabled={content.postchatEnabled}
  postchatButtonText={content.postchatButtonText}
  postchatButtonHref={content.postchatButtonHref}
  consoleHref={content.consoleHref}
  consoleTitle={content.consoleTitle}
  groups={content.groups}
>
  <div class="linkPage">
    <div class="linkPage_content">
      <DirectorySearch
        placeholder={content.search.placeholder}
        locale={content.search.locale}
        emptyTitle={content.search.emptyTitle}
        emptyDescription={content.search.emptyDescription}
      />

      <div class="directory-search-empty" id="directorySearchEmpty" hidden>
        <h3>{content.search.emptyTitle}</h3>
        <p>{content.search.emptyDescription}</p>
      </div>

      {
        visibleGroups.map((group) => (
            <div
              class="link_group"
              data-directory-group
              data-directory-group-id={group.anchorId}
            >
              {group.spec.displayName ? (
                <div class="link_group_title_content">
                  <i class={group.annotations.icon}></i>
                  <h2 class="link_group_title" id={group.anchorId}>
                    {group.spec.displayName}
                  </h2>
                </div>
              ) : null}

              <div class="link_group_content">
                {
                  group.links.map((link) => (
                    <a
                      class="link_group_content_link"
                      href={link.href}
                      data-directory-card
                      data-directory-card-id={link.cardId}
                      data-directory-card-group-id={group.anchorId}
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noreferrer noopener' : undefined}
                    >
                      <div class="link_group_content_item">
                        <div class="link_group_content_item_logo">
                          <img
                            class="link_group_content_item_logo_img"
                            src={link.displayLogo}
                            alt={link.spec.displayName}
                            loading="lazy"
                            decoding="async"
                            data-directory-card-logo
                            data-fallback-src="/directory/assets/logo-fallback.svg"
                          />
                        </div>
                        <div class="link_group_content_item_info">
                          <div class="link_group_content_item_info_content">
                            <p class="link_group_content_item_info_content_title">
                              {link.spec.displayName}
                            </p>
                            <p class="link_group_content_item_info_content_description">
                              {link.spec.description}
                            </p>
                          </div>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          ),
        )
      }

      {
        visibleGroups.length === 0 && (
          <div class="directory-content-empty">
            <h3>{emptyCopy.title}</h3>
            <p>{emptyCopy.description}</p>
          </div>
        )
      }

      <DirectoryTransparency locale={locale} />
    </div>
  </div>
</DirectoryLayout>

<style>
  .directory-search-empty {
    display: grid;
    gap: 0.5rem;
    margin: 1.5rem 0 2rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgb(221 228 248);
    border-radius: 20px;
    background: rgb(255 255 255 / 88%);
    color: #536176;
  }

  .directory-search-empty h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
  }

  .directory-search-empty p {
    margin: 0;
    line-height: 1.6;
  }

  .directory-content-empty {
    display: grid;
    gap: 0.5rem;
    margin: 0 0 2rem;
    padding: 1.4rem 1.5rem;
    border: 1px dashed rgb(191 205 240);
    border-radius: 20px;
    background: rgb(255 255 255 / 82%);
    color: #536176;
  }

  .directory-content-empty h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1f2937;
  }

  .directory-content-empty p {
    margin: 0;
    line-height: 1.7;
  }
</style>

<script>
  import { bootstrapRootInit } from '@/lib/dom-init';

  bootstrapRootInit(
    'directory-logo-fallback',
    '[data-directory-card]',
    (root, signal) => {
      const image = root.querySelector('[data-directory-card-logo]');

      if (!(image instanceof HTMLImageElement)) {
        return;
      }

      const fallbackSrc =
        image.dataset.fallbackSrc?.trim() || '/directory/assets/logo-fallback.svg';

      image.addEventListener(
        'error',
        () => {
          if (image.dataset.logoFallbackApplied === 'true') {
            return;
          }

          image.dataset.logoFallbackApplied = 'true';
          image.src = fallbackSrc;
        },
        { signal },
      );
    },
  );
</script>
