---
import { render } from 'astro:content';
import BlogCoverImage from '@/components/BlogCoverImage.astro';
import CategoryPill from '@/components/CategoryPill.astro';
import Container from '@/components/Container.astro';
import Giscus from '@/components/Giscus.astro';
import { IconArrowLeft as ArrowLeft } from '@/components/icons';
import { IconArrowRight as ArrowRight } from '@/components/icons';
import Layout from '@/layouts/Layout.astro';
import Prose from '@/components/Prose.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import Tag from '@/components/Tag.astro';
import { siteConfig } from '@/config/site';
import { formatDate, readingTime, wordCount } from '@/lib/formatter';
import { getSlug, type PostEntry } from '@/lib/posts';
import {
  getLocaleHomePath,
  getPostMarkdownPath,
  getPostOgImagePath,
  getPostPath,
  toAbsoluteSiteUrl,
} from '@/lib/site-content';
import { getMessages, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
  post: PostEntry;
  prevPost: PostEntry | null;
  nextPost: PostEntry | null;
}

const { locale, post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const m = getMessages(locale);
const slug = getSlug(post.id);
const postPath = getPostPath(locale, slug);
const postUrl = toAbsoluteSiteUrl(postPath);
const homeUrl = toAbsoluteSiteUrl(getLocaleHomePath(locale));
const articleJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    author: { '@type': 'Person', name: siteConfig.author.name },
    publisher: { '@type': 'Organization', name: siteConfig.name },
    url: postUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: siteConfig.name, item: homeUrl },
      { '@type': 'ListItem', position: 2, name: m.nav.blog, item: homeUrl },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
    ],
  },
];
---

<Layout
  title={`${post.data.title} | ${siteConfig.name}`}
  description={post.data.description}
  image={post.data.image ?? getPostOgImagePath(locale, slug)}
  jsonLd={articleJsonLd}
  enableCrisp={false}
  article={{
    publishedTime: post.data.date.toISOString(),
    author: siteConfig.author.name,
    tags: post.data.tags,
  }}
  alternateFormats={[
    {
      type: 'text/markdown',
      href: getPostMarkdownPath(locale, slug),
      title: `${post.data.title} (Markdown)`,
    },
  ]}
>
  <Container class="py-16 px-4">
    <div class="xl:grid xl:grid-cols-[1fr_220px] xl:gap-8">
      <article>
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <CategoryPill category={post.data.category} locale={locale} />
          {post.data.tags?.map((tag) => <Tag tag={tag} locale={locale} />)}
        </div>

        <h1 class="text-xl sm:text-2xl md:text-[31px] font-semibold mb-4 leading-[1.4] text-[var(--color-link)] break-words">{post.data.title}</h1>

        <div class="mb-8 flex flex-wrap items-center gap-x-3 gap-y-1 text-muted-foreground/60 text-xs font-mono" title={m.blog.readingTimeTooltip.replace('{words}', String(wordCount(post.body ?? ''))).replace('{minutes}', String(readingTime(post.body ?? '')))}>
          <span>{formatDate(post.data.date)}</span>
          <span>·</span>
          <span>{wordCount(post.body ?? '')} {m.blog.wordCount}</span>
          <span>·</span>
          <span>{readingTime(post.body ?? '')} {m.blog.minRead}</span>
        </div>

        {
          post.data.description && (
            <p class="mt-4 text-muted-foreground text-lg leading-relaxed">
              {post.data.description}
            </p>
          )
        }

        {post.data.image && (
          <div class="mt-6">
            <BlogCoverImage image={post.data.image} alt={post.data.title} />
          </div>
        )}

        <div class="mt-6 pt-10 border-t border-border">
          <Prose>
            <Content />
          </Prose>
        </div>

        <div class="mt-10 flex items-center gap-4">
          <span class="flex-1 border-t border-border"></span>
          <span class="text-sm text-muted-foreground">{m.blog.endOfPost}{m.blog.thanksForReading}</span>
          <span class="flex-1 border-t border-border"></span>
        </div>

        <nav class="mt-6 flex flex-col sm:flex-row items-stretch justify-between gap-4">
          {prevPost ? (
            <a
              href={getPostPath(locale, getSlug(prevPost.id))}
              class="group flex flex-col items-start text-sm hover:text-foreground sm:max-w-[45%] py-2"
            >
              <span class="inline-flex items-center gap-1 text-muted-foreground group-hover:text-foreground">
                <ArrowLeft className="size-3.5" />
                {m.blog.prevPost}
              </span>
              <span class="mt-1 text-[var(--color-link)] group-hover:text-[var(--color-link-hover)]">{prevPost.data.title}</span>
            </a>
          ) : <span />}
          {nextPost ? (
            <a
              href={getPostPath(locale, getSlug(nextPost.id))}
              class="group flex flex-col items-start sm:items-end text-sm hover:text-foreground sm:max-w-[45%] sm:ml-auto py-2"
            >
              <span class="inline-flex items-center gap-1 text-muted-foreground group-hover:text-foreground">
                {m.blog.nextPost}
                <ArrowRight className="size-3.5" />
              </span>
              <span class="mt-1 text-[var(--color-link)] group-hover:text-[var(--color-link-hover)]">{nextPost.data.title}</span>
            </a>
          ) : <span />}
        </nav>

        <Giscus locale={locale} />
      </article>
      <TableOfContents headings={headings} label={m.blog.onThisPage} />
    </div>
  </Container>
</Layout>
