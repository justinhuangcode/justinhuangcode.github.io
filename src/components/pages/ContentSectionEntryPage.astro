---
import type { CollectionKey } from 'astro:content';
import { render } from 'astro:content';
import ArticlePageBody from '@/components/pages/ArticlePageBody.astro';
import RecommendationsEntryContext from '@/components/recommendations/RecommendationsEntryContext.astro';
import TranslationEntryContext from '@/components/translations/TranslationEntryContext.astro';
import Layout from '@/layouts/Layout.astro';
import { siteConfig, type ContentSection } from '@/config/site';
import {
  getSectionFallbackLocale,
  getSectionContentLang,
  resolveSectionContentLocale,
  sectionHasFixedContentLocale,
} from '@/lib/content-sections';
import {
  getAvailableLocalesForSlug,
  getEntryLocale,
  getSlug,
  type LocalizedEntry,
} from '@/lib/posts';
import {
  getLocalizedRecommendationDescription,
  getLocalizedRecommendationDescriptionLang,
} from '@/lib/recommendations';
import { getRecommendationsUiCopy } from '@/lib/recommendations-ui';
import { getTranslationsUiCopy } from '@/lib/translations-ui';
import {
  htmlLangs,
  getLocalizedPath,
  getLocaleBasePath,
  translateNav,
  type Locale,
} from '@/i18n';

interface Props {
  locale: Locale;
  section: ContentSection;
  entry: LocalizedEntry<CollectionKey>;
  prevEntry: LocalizedEntry<CollectionKey> | null;
  nextEntry: LocalizedEntry<CollectionKey> | null;
}

const {
  locale,
  section,
  entry,
  prevEntry,
  nextEntry,
} = Astro.props;
const { Content, headings } = await render(entry);
const slug = getSlug(entry.id);
const basePath = getLocaleBasePath(locale);
const contentLocale = resolveSectionContentLocale(section, locale);
const usesFixedContentLocale = sectionHasFixedContentLocale(section);
const fallbackLocale = getSectionFallbackLocale(section);
const entryLocale = getEntryLocale(entry.id);
const usesSectionFallback = Boolean(fallbackLocale);
const isFallbackEntry = usesSectionFallback && entryLocale !== locale;
const canonicalLocale = usesFixedContentLocale ? contentLocale : entryLocale;
const canonicalPath = getLocalizedPath(`/${section.id}/${slug}`, canonicalLocale);
const entryUrl = `${siteConfig.url}${canonicalPath}/`;
const sectionTitleLocale = isFallbackEntry ? entryLocale : locale;
const sectionTitle = section.id === 'recommendations'
  ? getRecommendationsUiCopy(sectionTitleLocale).sectionTitle
  : section.id === 'translations'
    ? getTranslationsUiCopy(sectionTitleLocale).sectionTitle
    : translateNav(section.labelKey, sectionTitleLocale);
const recommendationsUiCopy = section.id === 'recommendations'
  ? getRecommendationsUiCopy(locale)
  : undefined;
const sectionIndexUrl = `${siteConfig.url}${getLocalizedPath(
  `/${section.id}`,
  isFallbackEntry ? entryLocale : contentLocale,
)}`;
const prevLink = prevEntry
  ? { href: `${basePath}/${section.id}/${getSlug(prevEntry.id)}/`, title: prevEntry.data.title }
  : null;
const nextLink = nextEntry
  ? { href: `${basePath}/${section.id}/${getSlug(nextEntry.id)}/`, title: nextEntry.data.title }
  : null;
const translationMeta = entry.data as typeof entry.data & {
  sourceLanguage?: string;
  sourceTitle?: string;
  sourceUrl?: string;
  translator?: string;
  sourcePublication?: string;
};
const contentLang = usesFixedContentLocale
  ? getSectionContentLang(section, locale)
  : htmlLangs[entryLocale];
const resolvedRecommendationDescription = section.id === 'recommendations'
  ? getLocalizedRecommendationDescription(slug, locale, entry.data.description)
  : entry.data.description;
const resolvedRecommendationDescriptionLang = section.id === 'recommendations'
  ? getLocalizedRecommendationDescriptionLang(slug, locale, contentLang)
  : contentLang;
const sourceUrl = translationMeta.sourceUrl
  ? new URL(translationMeta.sourceUrl, siteConfig.url).toString()
  : undefined;
const localeAlternates = usesSectionFallback
  ? (await getAvailableLocalesForSlug(section.id, slug)).map((availableLocale) => ({
      hreflang: htmlLangs[availableLocale],
      href: new URL(
        `${getLocalizedPath(`/${section.id}/${slug}`, availableLocale)}/`,
        siteConfig.url,
      ).toString(),
    }))
  : undefined;

const articleJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: resolvedRecommendationDescription,
    datePublished: entry.data.date.toISOString(),
    inLanguage: htmlLangs[entryLocale],
    author: { '@type': 'Person', name: siteConfig.author.name },
    publisher: { '@type': 'Organization', name: siteConfig.name },
    url: entryUrl,
    ...(sourceUrl ? { isBasedOn: sourceUrl } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: siteConfig.name, item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: sectionTitle, item: sectionIndexUrl },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: entryUrl },
    ],
  },
];
---

<Layout
  title={`${entry.data.title} | ${siteConfig.name}`}
  description={resolvedRecommendationDescription}
  image={entry.data.image ?? siteConfig.ogImage}
  jsonLd={articleJsonLd}
  canonicalUrl={entryUrl}
  hideLocaleAlternates={usesFixedContentLocale}
  localeAlternates={localeAlternates}
  article={{
    publishedTime: entry.data.date.toISOString(),
    author: siteConfig.author.name,
    tags: entry.data.tags,
  }}
>
  <ArticlePageBody
    locale={locale}
    entry={entry}
    content={Content}
    headings={headings}
    prevLink={prevLink}
    nextLink={nextLink}
    contentLang={contentLang}
    descriptionOverride={resolvedRecommendationDescription}
    descriptionLang={resolvedRecommendationDescriptionLang}
    descriptionPrefix={recommendationsUiCopy?.detailDescriptionLabel}
  >
    {
      section.id === 'recommendations' && (
        <RecommendationsEntryContext
          slot="above-description"
          locale={locale}
          sourceTitle={translationMeta.sourceTitle}
          sourcePublication={translationMeta.sourcePublication}
          sourceLanguage={translationMeta.sourceLanguage}
          sourceUrl={sourceUrl}
        />
      )
    }
    {
      section.id === 'translations' && (
        <TranslationEntryContext
          slot="above-description"
          locale={locale}
          sourceLanguage={translationMeta.sourceLanguage}
          sourceTitle={translationMeta.sourceTitle}
          sourceUrl={sourceUrl}
          translator={translationMeta.translator}
        />
      )
    }
  </ArticlePageBody>
</Layout>
