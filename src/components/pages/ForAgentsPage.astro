---
import { IconArrowRight } from '@/components/icons';
import Container from '@/components/Container.astro';
import { siteConfig } from '@/config/site';
import { getMessages, type Locale } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import { buildAgentDocumentUrls } from '@/lib/agent-protocol';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = getMessages(locale);
const docs = buildAgentDocumentUrls(locale);

function toPath(url: string): string {
  return new URL(url).pathname;
}

const discoveryOrder = [
  { label: 'protocol.json', href: toPath(docs.protocol) },
  { label: 'skill.md', href: toPath(docs.skill) },
  { label: 'agent/home.json', href: toPath(docs.agentHome) },
  { label: 'policy.md', href: toPath(docs.policy) },
  { label: 'reading.md', href: toPath(docs.reading) },
  { label: 'subscribe.md', href: toPath(docs.subscribe) },
  { label: 'auth.md', href: toPath(docs.auth) },
  { label: 'llms.txt', href: toPath(docs.llms) },
  { label: 'api/posts.json', href: toPath(docs.postsApi) },
];

const coreEndpoints = [
  { label: 'protocol.json', href: toPath(docs.protocol) },
  { label: 'skill.md', href: toPath(docs.skill) },
  { label: 'agent/home.json', href: toPath(docs.agentHome) },
  { label: 'policy.md', href: toPath(docs.policy) },
  { label: 'reading.md', href: toPath(docs.reading) },
  { label: 'llms.txt', href: toPath(docs.llms) },
  { label: 'subscribe.md', href: toPath(docs.subscribe) },
  { label: 'auth.md', href: toPath(docs.auth) },
];

const schemaEndpoints = [
  { label: 'agent-protocol.schema.json', href: toPath(docs.protocolSchema) },
  { label: 'agent-home.schema.json', href: toPath(docs.agentHomeSchema) },
];

const bestPractices = [
  m.forAgents.practice1,
  m.forAgents.practice2,
  m.forAgents.practice3,
  m.forAgents.practice4,
];

const capabilities = [
  m.forAgents.capabilityRead,
  m.forAgents.capabilityMarkdown,
  m.forAgents.capabilityMonitor,
  m.forAgents.capabilitySafe,
];
---

<Layout title={`${m.forAgents.title} | ${siteConfig.name}`} description={m.forAgents.description}>
  <Container class="px-4 py-16">
    <section
      class="relative overflow-hidden rounded-3xl border border-border/80 px-6 py-8 sm:px-8 sm:py-10"
      style="background-image: linear-gradient(135deg, color-mix(in oklab, var(--color-bg-hover) 88%, transparent), transparent 72%);"
    >
      <div class="relative z-[1] max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
          {m.forAgents.eyebrow}
        </p>
        <h1 class="mt-3 text-3xl font-semibold leading-tight text-[var(--color-link)] sm:text-[2.5rem]">
          {m.forAgents.title}
        </h1>
        <p class="mt-4 text-base leading-8 text-muted-foreground sm:text-lg">
          {m.forAgents.lead}
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={toPath(docs.protocol)}
            class="inline-flex min-h-[44px] items-center rounded-full bg-foreground px-4 py-2 text-sm font-medium text-background transition-colors hover:opacity-90"
          >
            {m.forAgents.openManifest}
          </a>
          <a
            href={toPath(docs.agentHome)}
            class="inline-flex min-h-[44px] items-center rounded-full border border-border bg-background/80 px-4 py-2 text-sm text-foreground transition-colors hover:border-foreground/20 hover:text-[var(--color-link)]"
          >
            {m.forAgents.openState}
          </a>
          <a
            href={toPath(docs.protocolSchema)}
            class="inline-flex min-h-[44px] items-center rounded-full border border-border bg-background/80 px-4 py-2 text-sm text-foreground transition-colors hover:border-foreground/20 hover:text-[var(--color-link)]"
          >
            agent-protocol.schema.json
          </a>
        </div>
      </div>
    </section>

    <div class="mt-8 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
      <section class="rounded-2xl border border-border/80 bg-background/70 p-6">
        <h2 class="text-lg font-semibold text-foreground">{m.forAgents.discoveryTitle}</h2>
        <ol class="mt-5 space-y-3">
          {
            discoveryOrder.map((item, index) => (
              <li class="flex gap-4">
                <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-border bg-background text-xs font-semibold text-muted-foreground">
                  {index + 1}
                </span>
                <div class="min-w-0">
                  <a
                    href={item.href}
                    class="font-mono text-sm text-[var(--color-link)] transition-colors hover:text-[var(--color-link-hover)]"
                  >
                    {item.label}
                  </a>
                  <p class="mt-1 break-all text-xs text-muted-foreground">{item.href}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="rounded-2xl border border-border/80 bg-background/70 p-6">
        <h2 class="text-lg font-semibold text-foreground">{m.forAgents.capabilitiesTitle}</h2>
        <ul class="mt-5 space-y-3">
          {
            capabilities.map((item) => (
              <li class="flex gap-3 text-sm leading-7 text-muted-foreground">
                <span class="mt-[0.8rem] inline-block size-1.5 shrink-0 rounded-full bg-[var(--color-link)]"></span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <section class="mt-8 rounded-2xl border border-border/80 bg-background/70 p-6">
      <h2 class="text-lg font-semibold text-foreground">{m.forAgents.docsTitle}</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {
          coreEndpoints.map((item) => (
            <a
              href={item.href}
              class="group rounded-2xl border border-border/70 bg-background/70 p-4 transition-colors hover:border-foreground/20 hover:text-[var(--color-link)]"
            >
              <div class="flex items-center justify-between gap-3">
                <code class="font-mono text-sm text-foreground">{item.label}</code>
                <IconArrowRight className="size-4 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-[var(--color-link)]" />
              </div>
              <p class="mt-2 break-all text-xs text-muted-foreground">{item.href}</p>
            </a>
          ))
        }
      </div>
    </section>

    <div class="mt-8 grid gap-6 xl:grid-cols-[0.85fr_1.15fr]">
      <section class="rounded-2xl border border-border/80 bg-background/70 p-6">
        <h2 class="text-lg font-semibold text-foreground">{m.forAgents.schemasTitle}</h2>
        <div class="mt-5 space-y-3">
          {
            schemaEndpoints.map((item) => (
              <a
                href={item.href}
                class="block rounded-2xl border border-border/70 bg-background/70 p-4 transition-colors hover:border-foreground/20 hover:text-[var(--color-link)]"
              >
                <code class="font-mono text-sm text-foreground">{item.label}</code>
                <p class="mt-2 break-all text-xs text-muted-foreground">{item.href}</p>
              </a>
            ))
          }
        </div>
      </section>

      <section class="rounded-2xl border border-border/80 bg-background/70 p-6">
        <h2 class="text-lg font-semibold text-foreground">{m.forAgents.bestPracticesTitle}</h2>
        <ul class="mt-5 space-y-3">
          {
            bestPractices.map((item) => (
              <li class="flex gap-3 text-sm leading-7 text-muted-foreground">
                <span class="mt-[0.8rem] inline-block size-1.5 shrink-0 rounded-full bg-[var(--color-link)]"></span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</Layout>
