---
import type { CollectionKey } from 'astro:content';
import BlogCard from '@/components/BlogCard.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import ContentSectionHeader from '@/components/ContentSectionHeader.astro';
import Container from '@/components/Container.astro';
import TranslationShelfNotice from '@/components/translations/TranslationShelfNotice.astro';
import { siteConfig, type ContentSection } from '@/config/site';
import {
  getLocaleBasePath,
  getLocalizedPath,
  getMessages,
  intlLocales,
  translateNav,
  type Locale,
} from '@/i18n';
import {
  getSectionContentLang,
  resolveSectionContentLocale,
  sectionHasFixedContentLocale,
} from '@/lib/content-sections';
import { getSlug, type LocalizedEntry } from '@/lib/posts';
import Layout from '@/layouts/Layout.astro';

interface Props {
  locale: Locale;
  section: ContentSection;
  entries: Array<LocalizedEntry<CollectionKey>>;
}

const { locale, section, entries } = Astro.props;
const title = translateNav(section.labelKey, locale);
const basePath = getLocaleBasePath(locale);
const m = getMessages(locale);
const totalEntriesLabel = m.blog.totalPosts.replace(
  '{count}',
  new Intl.NumberFormat(intlLocales[locale]).format(entries.length),
);
const fixedContentLocale = resolveSectionContentLocale(section, locale);
const usesFixedContentLocale = sectionHasFixedContentLocale(section);
const contentLang = usesFixedContentLocale
  ? getSectionContentLang(section, locale)
  : undefined;
const canonicalUrl = usesFixedContentLocale
  ? new URL(getLocalizedPath(`/${section.id}`, fixedContentLocale), siteConfig.url).toString()
  : undefined;
---

<Layout
  title={`${title} | ${siteConfig.name}`}
  canonicalUrl={canonicalUrl}
  hideLocaleAlternates={usesFixedContentLocale}
>
  {
    entries.length > 0 && (
      <section class="content-index-zone">
        <Container class="px-4">
          <div class="content-index-shell">
            {section.id === 'translations' && <TranslationShelfNotice locale={locale} />}
            <ContentSectionHeader title={title} countLabel={totalEntriesLabel} headingAs="h1" />
            <BlogGrid>
              {
                entries.map((entry) => (
                  <BlogCard
                    slug={getSlug(entry.id)}
                    title={entry.data.title}
                    date={entry.data.date}
                    basePath={basePath}
                    section={section.id}
                    pinned={entry.data.pinned}
                    titleLang={contentLang}
                  />
                ))
              }
            </BlogGrid>
          </div>
        </Container>
      </section>
    )
  }
</Layout>

<style>
  .content-index-zone {
    background: var(--background);
    padding-block: 0.01rem 2.5rem;
  }

  .content-index-shell {
    margin-top: 2.1rem;
  }

  .content-index-shell :global(.blog-grid) {
    width: 100%;
    max-width: none;
    margin-inline: 0;
    margin-bottom: 1.95rem;
  }

  @media (min-width: 992px) {
    .content-index-shell {
      margin-top: 2.8rem;
    }
  }
</style>
