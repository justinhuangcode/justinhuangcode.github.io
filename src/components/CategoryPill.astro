---
/**
 * CategoryPill — colored capsule for post categories.
 * Color is deterministic based on the English key for cross-locale consistency.
 */
import { translateCategory } from '@/i18n';

interface Props {
  category: string;
  locale?: string;
}

const { category, locale = 'en' } = Astro.props;
const displayCategory = translateCategory(category, locale);

const colors = [
  '#2563eb', // 蓝
  '#7c3aed', // 紫
  '#0891b2', // 青
  '#059669', // 绿
  '#d97706', // 琥珀
  '#dc2626', // 红
  '#db2777', // 粉
  '#4f46e5', // 靛蓝
  '#0d9488', // 蓝绿
  '#ea580c', // 橙
];

// Fixed color overrides for specific categories
const fixedColors: Record<string, string> = {
  'OpenClaw': '#f70515',
};

// Use fixed color if available, otherwise deterministic hash
let bg: string;
if (fixedColors[category]) {
  bg = fixedColors[category];
} else {
  let hash = 0;
  for (let i = 0; i < category.length; i++) {
    hash = ((hash << 5) - hash + category.charCodeAt(i)) | 0;
  }
  bg = colors[Math.abs(hash) % colors.length];
}
---

<span
  class="inline-block rounded-full px-2.5 py-0.5 text-xs font-mono font-bold text-white"
  style={`background:${bg}`}
>
  {displayCategory}
</span>
