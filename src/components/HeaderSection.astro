---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<div class="mx-auto max-w-2xl text-center">
  <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
  {
    description && (
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        {description}
      </p>
    )
  }
</div>
