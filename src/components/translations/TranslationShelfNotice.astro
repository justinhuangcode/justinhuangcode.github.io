---
import { getTranslationsUiCopy } from '@/lib/translations-ui';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getTranslationsUiCopy(locale);
---

<section class="translation-shelf-notice" aria-label={copy.shelfTitle}>
  <p class="translation-shelf-eyebrow">{copy.shelfEyebrow}</p>
  <p class="translation-shelf-title">{copy.shelfTitle}</p>
  <p class="translation-shelf-description">{copy.shelfDescription}</p>
  <p class="translation-shelf-note">{copy.shelfNote}</p>
</section>

<style>
  .translation-shelf-notice {
    margin-bottom: 1.4rem;
    padding: 1rem 1.05rem;
    border: 1px solid color-mix(in srgb, var(--border) 90%, transparent);
    border-radius: 1.15rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--background) 94%, transparent), var(--background));
  }

  .translation-shelf-eyebrow {
    margin: 0 0 0.45rem;
    color: color-mix(in srgb, var(--muted-foreground) 88%, transparent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .translation-shelf-title {
    margin: 0;
    color: var(--foreground);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .translation-shelf-description,
  .translation-shelf-note {
    margin: 0.45rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.93rem;
    line-height: 1.7;
  }

  .translation-shelf-note {
    font-size: 0.85rem;
  }

  @media (min-width: 768px) {
    .translation-shelf-notice {
      padding: 1.15rem 1.2rem;
    }
  }
</style>
