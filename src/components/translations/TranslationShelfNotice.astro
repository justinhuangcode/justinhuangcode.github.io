---
import { getTranslationsUiCopy } from '@/lib/translations-ui';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getTranslationsUiCopy(locale);
---

<section class="translation-shelf-notice" aria-label={copy.shelfTitle}>
  <p class="translation-shelf-eyebrow">{copy.shelfEyebrow}</p>
  <p class="translation-shelf-title">{copy.shelfTitle}</p>
  <p class="translation-shelf-description">{copy.shelfDescription}</p>
</section>

<style>
  .translation-shelf-notice {
    margin-bottom: 1.4rem;
    padding: 1.02rem 1.05rem;
    border: 1px solid color-mix(in srgb, var(--border) 92%, transparent);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--background) 97%, white 3%), var(--background));
  }

  .translation-shelf-eyebrow {
    margin: 0 0 0.42rem;
    color: color-mix(in srgb, var(--muted-foreground) 86%, transparent);
    font-family: var(--font-code);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .translation-shelf-title {
    margin: 0;
    color: var(--foreground);
    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .translation-shelf-description {
    margin: 0.48rem 0 0;
    color: var(--muted-foreground);
    font-size: 0.94rem;
    line-height: 1.72;
  }
</style>
