      <circle class="network-node network-node--cool" cx="612" cy="92" r="2.7" style="animation-delay:-0.9s" />
      <circle class="network-node" cx="770" cy="208" r="2.8" style="animation-delay:-1.7s" />
      <circle class="network-node network-node--dim" cx="926" cy="102" r="2.1" style="animation-delay:-2.5s" />
