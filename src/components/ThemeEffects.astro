      <circle class="network-node network-node--cool" cx="1086" cy="756" r="2.9" style="animation-delay:-4.4s" />

      <circle class="network-node network-node--cool" cx="1252" cy="888" r="2.8" style="animation-delay:-1.3s" />
      <circle class="network-node" cx="1390" cy="986" r="2.7" style="animation-delay:-2.6s" />
      <circle class="network-node network-node--dim" cx="1516" cy="876" r="2.2" style="animation-delay:-3.2s" />
      <circle class="network-node" cx="1452" cy="1124" r="2.6" style="animation-delay:-4.1s" />
      <circle class="network-node network-node--cool" cx="1556" cy="1034" r="2.8" style="animation-delay:-2.2s" />
    </svg>
  </div>
  <div class="theme-scene-glow"></div>
  <div class="theme-scene-motion"></div>
</div>

<style is:global>
  .theme-scene {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    isolation: isolate;
  }

  .theme-scene-base,
  .theme-scene-pattern,
  .theme-scene-canvas,
  .theme-scene-network,
  .theme-scene-glow,
  .theme-scene-motion {
    position: absolute;
    inset: 0;
    transform: translateZ(0);
    will-change: transform, opacity, background-position, filter;
  }

  .theme-scene-pattern,
  .theme-scene-canvas,
  .theme-scene-network,
  .theme-scene-glow,
  .theme-scene-motion {
    opacity: 0;
  }

  .theme-scene-canvas {
    width: 100%;
    height: 100%;
  }

  .theme-scene-pattern {
    background-repeat: repeat;
  }

  .theme-scene-glow,
  .theme-scene-motion {
    background-repeat: no-repeat;
    background-size: cover;
  }

  .theme-scene-network {
    inset: -6%;
    overflow: visible;
  }

  .theme-scene-network svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .theme-scene-network .network-line {
    fill: none;
    stroke: rgba(115, 223, 255, 0.24);
    stroke-width: 1.35;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
    filter: drop-shadow(0 0 5px rgba(84, 162, 255, 0.14));
  }

  .theme-scene-network .network-line--soft {
    stroke: rgba(98, 186, 255, 0.2);
  }

  .theme-scene-network .network-line--bright {
    stroke: rgba(157, 246, 232, 0.36);
  }

  .theme-scene-network .network-node {
    fill: rgba(157, 246, 232, 0.82);
    opacity: 0.7;
    filter: drop-shadow(0 0 8px rgba(105, 174, 252, 0.44));
    transform-box: fill-box;
    transform-origin: center;
  }

  .theme-scene-network .network-node--cool {
    fill: rgba(105, 174, 252, 0.88);
  }

  .theme-scene-network .network-node--dim {
    fill: rgba(223, 237, 255, 0.42);
    opacity: 0.42;
    filter: none;
  }

  .theme-scene-pattern::before,
  .theme-scene-pattern::after,
  .theme-scene-glow::before,
  .theme-scene-glow::after,
  .theme-scene-motion::before,
  .theme-scene-motion::after {
    content: '';
    position: absolute;
    inset: -12%;
    opacity: 0;
    pointer-events: none;
    background-repeat: no-repeat;
    background-size: cover;
    transform: translateZ(0);
    will-change: transform, opacity, background-position, filter;
  }

  /* ── Cyberpunk ── */
  html:is(.cyberpunk, [data-theme='cyberpunk']) .theme-scene-base {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.16) 0%, transparent 20%),
      radial-gradient(circle at 82% 82%, rgba(246, 51, 154, 0.14) 0%, transparent 22%),
      linear-gradient(180deg, #ffe100 0%, #ffd500 52%, #ffc800 100%);
  }
  html:is(.cyberpunk, [data-theme='cyberpunk']) .theme-scene-pattern {
    opacity: 1;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.07) 0,
        rgba(0, 0, 0, 0.07) 1px,
        transparent 1px,
        transparent 64px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.06) 0,
        rgba(0, 0, 0, 0.06) 1px,
        transparent 1px,
        transparent 64px
      );
    background-size: 64px 64px, 64px 64px;
  }
  html:is(.cyberpunk, [data-theme='cyberpunk']) .theme-scene-pattern::before {
    opacity: 0.46;
    background:
      repeating-linear-gradient(
        135deg,
        transparent 0 28px,
        rgba(0, 0, 0, 0.08) 28px 32px,
        transparent 32px 72px
      );
  }
  html:is(.cyberpunk, [data-theme='cyberpunk']) .theme-scene-glow {
    opacity: 1;
    background:
      radial-gradient(circle at 20% 75%, rgba(0, 210, 239, 0.14) 0%, transparent 28%),
      radial-gradient(circle at 80% 20%, rgba(246, 51, 154, 0.14) 0%, transparent 24%);
    animation: cyberpunk-pulse 7s ease-in-out infinite alternate;
  }
  html:is(.cyberpunk, [data-theme='cyberpunk']) .theme-scene-motion {
    opacity: 1;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14) 0%, transparent 18%, transparent 82%, rgba(0, 0, 0, 0.06) 100%);
    animation: cyberpunk-scan 10s linear infinite;
  }
  html:is(.cyberpunk, [data-theme='cyberpunk']) .theme-scene-motion::before {
    opacity: 0.32;
    background:
      linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.12) 52%, transparent 100%);
    animation: cyberpunk-scan 14s linear infinite reverse;
  }

  /* ── Matrix ── */
  html:is(.matrix, [data-theme='matrix']) .theme-scene-base {
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 64, 24, 0.42) 0%, transparent 30%),
      radial-gradient(circle at 50% 100%, rgba(0, 255, 65, 0.08) 0%, transparent 40%),
      linear-gradient(180deg, #041108 0%, #010602 45%, #000000 100%);
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-pattern {
    opacity: 0;
    background: none;
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-matrix-canvas {
    opacity: 0.6;
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-pattern::before {
    opacity: 0;
    background: none;
    filter: none;
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-glow {
    opacity: 0;
    background: none;
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-glow::before {
    opacity: 0;
    background: none;
    filter: none;
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-motion {
    opacity: 0;
    background: none;
  }
  html:is(.matrix, [data-theme='matrix']) .theme-scene-motion::before {
    opacity: 0;
    background: none;
    filter: none;
  }

  /* ── Black Mirror ── */
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-base {
    background:
      radial-gradient(circle at 50% 16%, rgba(255, 255, 255, 0.04) 0%, transparent 26%),
      linear-gradient(180deg, #131415 0%, #0a0a0b 100%);
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-pattern {
    opacity: 0;
    background: none;
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-pattern::before {
    opacity: 0;
    background: none;
    animation: none;
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-blackmirror-canvas {
    opacity: 1;
    mix-blend-mode: screen;
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-glow {
    opacity: 0;
    background: none;
    mix-blend-mode: normal;
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-glow::before {
    opacity: 0;
    background: none;
    filter: none;
    animation: none;
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-motion {
    opacity: 0;
    background: none;
    animation: none;
  }
  html:is(.blackmirror, [data-theme='blackmirror']) .theme-scene-motion::before {
    opacity: 0;
    background: none;
    animation: none;
  }

  /* ── Evolution ── */
  html:is(.evolution, [data-theme='evolution']) .theme-scene-base {
    background:
      radial-gradient(circle at 12% 16%, rgba(56, 189, 248, 0.16) 0%, transparent 24%),
      radial-gradient(circle at 85% 10%, rgba(45, 212, 191, 0.1) 0%, transparent 18%),
      radial-gradient(circle at 24% 88%, rgba(37, 99, 235, 0.1) 0%, transparent 24%),
      linear-gradient(180deg, #091121 0%, #050a15 58%, #030711 100%);
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-pattern {
    opacity: 0.72;
    background-repeat: no-repeat;
    background-image:
      radial-gradient(circle at 50% -12%, rgba(226, 232, 240, 0.05) 0%, transparent 38%),
      linear-gradient(180deg, rgba(148, 163, 184, 0.055) 0%, rgba(148, 163, 184, 0.018) 10%, transparent 26%, transparent 100%),
      radial-gradient(circle at 22% 22%, rgba(84, 162, 255, 0.08) 0%, transparent 18%),
      radial-gradient(circle at 78% 16%, rgba(45, 212, 191, 0.06) 0%, transparent 16%);
    animation: evo-network-float 28s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-network {
    opacity: 1;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-network-a {
    animation: evo-svg-drift-a 30s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-network-b {
    animation: evo-svg-drift-b 36s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-network-a .network-line {
    animation: evo-line-fade 10s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-network-b .network-line {
    animation: evo-line-fade 12s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-network .network-node {
    animation: evo-node-pulse 5.8s ease-in-out infinite;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-pattern::before {
    opacity: 0.62;
    background-image:
      linear-gradient(60deg, transparent 49.1%, rgba(115, 223, 255, 0.16) 49.6%, rgba(115, 223, 255, 0.16) 50.2%, transparent 50.7%),
      linear-gradient(122deg, transparent 49.1%, rgba(86, 177, 255, 0.13) 49.6%, rgba(86, 177, 255, 0.13) 50.2%, transparent 50.7%),
      radial-gradient(circle, rgba(157, 246, 232, 0.95) 0 1.2px, transparent 1.9px),
      radial-gradient(circle, rgba(91, 192, 255, 0.8) 0 1.15px, transparent 1.8px),
      linear-gradient(51deg, transparent 49.2%, rgba(82, 195, 255, 0.11) 49.7%, rgba(82, 195, 255, 0.11) 50.2%, transparent 50.7%),
      linear-gradient(104deg, transparent 49.2%, rgba(148, 244, 227, 0.1) 49.7%, rgba(148, 244, 227, 0.1) 50.2%, transparent 50.7%),
      radial-gradient(circle, rgba(148, 244, 227, 0.78) 0 1.2px, transparent 1.8px),
      radial-gradient(circle, rgba(84, 162, 255, 0.72) 0 1.1px, transparent 1.7px),
      linear-gradient(72deg, transparent 49.2%, rgba(84, 162, 255, 0.1) 49.7%, rgba(84, 162, 255, 0.1) 50.2%, transparent 50.7%),
      radial-gradient(circle, rgba(157, 246, 232, 0.72) 0 1.2px, transparent 1.8px),
      radial-gradient(circle, rgba(84, 162, 255, 0.62) 0 1.1px, transparent 1.7px);
    background-size:
      18rem 13rem,
      18rem 13rem,
      18rem 13rem,
      18rem 13rem,
      16rem 12rem,
      16rem 12rem,
      16rem 12rem,
      16rem 12rem,
      22rem 16rem,
      22rem 16rem,
      22rem 16rem;
    background-position:
      73% 2%,
      73% 2%,
      72% 2%,
      81% 10%,
      6% 55%,
      6% 55%,
      10% 63%,
      16% 52%,
      67% 70%,
      73% 79%,
      84% 68%;
    animation: evo-network-drift 24s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-pattern::after {
    opacity: 0.34;
    background-image:
      linear-gradient(114deg, transparent 49.3%, rgba(148, 244, 227, 0.08) 49.75%, rgba(148, 244, 227, 0.08) 50.25%, transparent 50.7%),
      linear-gradient(132deg, transparent 49.3%, rgba(84, 162, 255, 0.07) 49.75%, rgba(84, 162, 255, 0.07) 50.25%, transparent 50.7%),
      radial-gradient(circle, rgba(157, 246, 232, 0.5) 0 1px, transparent 1.5px),
      radial-gradient(circle, rgba(84, 162, 255, 0.46) 0 1px, transparent 1.5px),
      radial-gradient(circle, rgba(223, 237, 255, 0.3) 0 1px, transparent 1.5px);
    background-size:
      24rem 18rem,
      24rem 18rem,
      24rem 18rem,
      24rem 18rem,
      24rem 18rem;
    background-position:
      32% 20%,
      48% 24%,
      28% 26%,
      44% 38%,
      58% 24%;
    filter: blur(0.15px);
    animation: evo-orbit 30s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-glow {
    opacity: 1;
    background:
      radial-gradient(circle at 18% 76%, rgba(34, 197, 94, 0.14) 0%, transparent 28%),
      radial-gradient(circle at 84% 16%, rgba(84, 162, 255, 0.2) 0%, transparent 30%),
      radial-gradient(circle at 48% 40%, rgba(56, 189, 248, 0.05) 0%, transparent 22%);
    mix-blend-mode: screen;
    animation: evo-drift 18s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-glow::before {
    opacity: 0.78;
    background:
      radial-gradient(circle at 20% 70%, rgba(16, 185, 129, 0.16) 0%, transparent 16%),
      radial-gradient(circle at 84% 20%, rgba(59, 130, 246, 0.2) 0%, transparent 18%),
      radial-gradient(circle at 52% 12%, rgba(226, 232, 240, 0.06) 0%, transparent 14%);
    filter: blur(42px);
    animation: evo-orbit 20s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-motion {
    opacity: 1;
    background:
      linear-gradient(180deg, rgba(148, 163, 184, 0.04) 0%, transparent 22%, transparent 78%, rgba(56, 189, 248, 0.055) 100%),
      radial-gradient(circle at 50% -24%, rgba(255, 255, 255, 0.045) 0%, transparent 40%);
    animation: evo-pulse 8s ease-in-out infinite alternate;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-motion::before {
    opacity: 0.38;
    background:
      linear-gradient(108deg, transparent 12%, rgba(94, 234, 212, 0.065) 35%, transparent 52%),
      linear-gradient(128deg, transparent 54%, rgba(56, 189, 248, 0.085) 70%, transparent 84%);
    background-size: 180% 180%;
    animation: evo-sweep 13s ease-in-out infinite;
  }
  html:is(.evolution, [data-theme='evolution']) .theme-scene-motion::after {
    opacity: 0.2;
    background:
      radial-gradient(circle at 12% 16%, rgba(148, 244, 227, 0.28) 0 1px, transparent 1.4px),
      radial-gradient(circle at 52% 18%, rgba(82, 195, 255, 0.22) 0 1px, transparent 1.4px),
      radial-gradient(circle at 78% 10%, rgba(148, 244, 227, 0.22) 0 1px, transparent 1.4px),
      radial-gradient(circle at 24% 72%, rgba(16, 185, 129, 0.18) 0 1px, transparent 1.4px),
      radial-gradient(circle at 68% 60%, rgba(82, 195, 255, 0.2) 0 1px, transparent 1.4px);
    filter: blur(0.4px);
    animation: evo-twinkle 7s ease-in-out infinite alternate;
  }

  /* ── Protoss ── */
  html:is(.protoss, [data-theme='protoss']) .theme-scene-base {
