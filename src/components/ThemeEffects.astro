      if (animate) {
        bodies.forEach((body, index) => {
          scene.trails[index].unshift({ x: body.x, y: body.y });
          scene.trails[index].length = 28;
        });
      }

      const step = 72;
      const sample = 36;
      context.lineWidth = 1;
      for (let y = 0; y <= height; y += step) {
        context.beginPath();
        for (let x = 0; x <= width; x += sample) {
          let warpX = x;
          let warpY = y;
          bodies.forEach((body) => {
            const dx = body.x - x;
            const dy = body.y - y;
            const distance = Math.max(80, Math.sqrt(dx * dx + dy * dy));
            const force = 1800 / distance;
            warpX += (dx / distance) * force;
            warpY += (dy / distance) * force;
          });
          if (x === 0) {
            context.moveTo(warpX, warpY);
          } else {
            context.lineTo(warpX, warpY);
          }
        }
        context.strokeStyle = 'rgba(248, 113, 113, 0.12)';
        context.stroke();
      }

      for (let x = 0; x <= width; x += step) {
        context.beginPath();
        for (let y = 0; y <= height; y += sample) {
          let warpX = x;
          let warpY = y;
          bodies.forEach((body) => {
            const dx = body.x - x;
            const dy = body.y - y;
            const distance = Math.max(80, Math.sqrt(dx * dx + dy * dy));
            const force = 1800 / distance;
            warpX += (dx / distance) * force;
            warpY += (dy / distance) * force;
          });
          if (y === 0) {
            context.moveTo(warpX, warpY);
          } else {
            context.lineTo(warpX, warpY);
          }
        }
        context.strokeStyle = 'rgba(255, 255, 255, 0.06)';
