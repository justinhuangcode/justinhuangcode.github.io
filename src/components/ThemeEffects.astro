<script is:inline>
  (() => {
    const canvas = document.querySelector('.theme-scene-matrix-canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext('2d', { alpha: true });
    if (!context) return;

    const root = document.documentElement;
    const media = window.matchMedia('(prefers-reduced-motion: reduce)');
    const glyphs = '0123456789ABCDEF';
    const cellWidth = 20;
    const cellHeight = 20;

    let width = 0;
    let height = 0;
    let rafId = 0;
    let drops = [];

    const isMatrixTheme = () =>
      root.classList.contains('matrix') || root.getAttribute('data-theme') === 'matrix';

    const resetDrops = () => {
      const columns = Math.max(1, Math.ceil(width / cellWidth));
      drops = Array(columns).fill(1);
    };

    const resizeCanvas = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(window.innerWidth, document.documentElement.clientWidth);
      height = Math.max(window.innerHeight, document.documentElement.clientHeight);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
      context.font = '15px monospace';
      context.textBaseline = 'top';
      resetDrops();
    };

    const clearCanvas = () => {
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.clearRect(0, 0, canvas.width, canvas.height);
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const drawFrame = () => {
      if (!isMatrixTheme()) {
        rafId = 0;
        clearCanvas();
        return;
      }

      context.fillStyle = 'rgba(0, 0, 0, 0.05)';
      context.fillRect(0, 0, width, height);
      context.font = '15px monospace';

      for (let index = 0; index < drops.length; index += 1) {
        const x = index * cellWidth;
        const y = drops[index] * cellHeight;
        const glyph = glyphs[(Math.random() * glyphs.length) | 0];
        context.fillStyle = '#0F0';
        context.fillText(glyph, x, y);

        if (y > height && Math.random() > 0.975) {
          drops[index] = 0;
        } else {
          drops[index] += 1;
        }
      }

      rafId = window.requestAnimationFrame(drawFrame);
    };

    const renderStaticWall = () => {
      clearCanvas();
      context.fillStyle = 'rgba(0, 0, 0, 0.82)';
      context.fillRect(0, 0, width, height);

      for (let pass = 0; pass < 18; pass += 1) {
        for (let index = 0; index < drops.length; index += 1) {
          const rowCount = Math.max(1, Math.ceil(height / cellHeight));
          const x = index * cellWidth;
          const y = ((drops[index] + pass * 2) % rowCount) * cellHeight;
          const glyph = glyphs[(Math.random() * glyphs.length) | 0];
          const alpha = 0.22 + Math.random() * 0.18;
          context.fillStyle = `rgba(86, 255, 132, ${alpha})`;
          context.fillText(glyph, x, y);
        }
      }
    };

    const syncMatrixScene = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }

      if (!isMatrixTheme()) {
        clearCanvas();
        return;
      }

      resizeCanvas();

      clearCanvas();

      if (media.matches) {
        renderStaticWall();
        return;
      }

      drawFrame();
    };

    resizeCanvas();
    syncMatrixScene();

    const observer = new MutationObserver(syncMatrixScene);
    observer.observe(root, {
      attributes: true,
      attributeFilter: ['class', 'data-theme'],
    });

    window.addEventListener('resize', syncMatrixScene);
    media.addEventListener('change', syncMatrixScene);
  })();
</script>

<script is:inline>
  (() => {
    const canvas = document.querySelector('.theme-scene-blackmirror-canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext('2d', { alpha: true });
    if (!context) return;

    const root = document.documentElement;
    const media = window.matchMedia('(prefers-reduced-motion: reduce)');

    class BlackMirrorShard {
      constructor(width, height) {
        this.width = width;
        this.height = height;
        this.reset();
      }

      reset() {
        this.x = Math.random() * this.width;
        this.y = Math.random() * this.height;
        this.z = Math.random() * 2 + 0.5;
        this.size = Math.random() * 56 + 34;
        this.vx = (Math.random() - 0.5) * 0.22;
        this.vy = (Math.random() - 0.5) * 0.22;
        this.angle = Math.random() * Math.PI * 2;
        this.rotationSpeed = (Math.random() - 0.5) * 0.015;
        this.opacity = Math.random() * 0.22 + 0.16;
      }

      update(width, height) {
        this.width = width;
        this.height = height;
        this.x += this.vx * this.z;
        this.y += this.vy * this.z;
        this.angle += this.rotationSpeed;

        if (this.x < -150 || this.x > this.width + 150 || this.y < -150 || this.y > this.height + 150) {
          this.reset();
        }
      }

      draw(time) {
        context.save();
        context.translate(this.x, this.y);
        context.rotate(this.angle);
        context.globalAlpha = this.opacity;
        context.beginPath();
        context.moveTo(0, -this.size);
        context.lineTo(this.size * 0.6, this.size * 0.8);
        context.lineTo(-(this.size * 0.5), this.size * 0.4);
        context.closePath();

        const pulse = Math.pow(Math.abs(Math.sin(0.3 * time + this.x * 0.005 + this.y * 0.005)), 4);
        context.fillStyle = `rgba(214, 226, 242, ${0.08 + 0.28 * pulse})`;
        context.fill();
        context.strokeStyle = `rgba(255, 255, 255, ${0.24 + 0.56 * pulse})`;
        context.lineWidth = 1;
        context.stroke();
        context.restore();
      }
    }

    let width = 0;
    let height = 0;
    let rafId = 0;
    let time = 0;
    let shards = [];

    const isBlackMirrorTheme = () =>
      root.classList.contains('blackmirror') || root.getAttribute('data-theme') === 'blackmirror';

    const resizeCanvas = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(window.innerWidth, document.documentElement.clientWidth);
      height = Math.max(window.innerHeight, document.documentElement.clientHeight);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);

      if (!shards.length) {
        shards = Array.from({ length: 34 }, () => new BlackMirrorShard(width, height));
        return;
      }

      shards.forEach((shard) => {
        shard.width = width;
        shard.height = height;
      });
    };

    const clearCanvas = () => {
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.clearRect(0, 0, canvas.width, canvas.height);
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const drawOverlay = () => {
      const radius = Math.max(width, height);
      const vignette = context.createRadialGradient(width / 2, height / 2, width / 3, width / 2, height / 2, radius);
      vignette.addColorStop(0, 'rgba(0, 0, 0, 0)');
      vignette.addColorStop(1, 'rgba(0, 0, 0, 0.42)');
      context.fillStyle = vignette;
      context.fillRect(0, 0, width, height);

      const recAlpha = Math.sin(3 * time) > 0 ? 0.8 : 0.2;
      context.fillStyle = `rgba(200, 0, 0, ${recAlpha})`;
      context.beginPath();
      context.arc(30, 30, 4, 0, Math.PI * 2);
      context.fill();
      context.fillStyle = 'rgba(255, 255, 255, 0.4)';
      context.font = '10px sans-serif';
      context.fillText('REC', 42, 33);
    };

    const drawFrame = () => {
      if (!isBlackMirrorTheme()) {
        rafId = 0;
        clearCanvas();
        return;
      }

      time += 0.01;
      clearCanvas();
      shards.forEach((shard) => {
        shard.update(width, height);
        shard.draw(time);
      });
      drawOverlay();
      rafId = window.requestAnimationFrame(drawFrame);
    };

    const renderStaticFrame = () => {
      clearCanvas();
      shards.forEach((shard) => shard.draw(0));
      drawOverlay();
    };

    const syncBlackMirrorScene = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }

      if (!isBlackMirrorTheme()) {
        clearCanvas();
        return;
      }

      resizeCanvas();
      time = 0;

      if (media.matches) {
        renderStaticFrame();
        return;
      }

      drawFrame();
    };

    resizeCanvas();
    syncBlackMirrorScene();

    const observer = new MutationObserver(syncBlackMirrorScene);
    observer.observe(root, {
      attributes: true,
      attributeFilter: ['class', 'data-theme'],
    });

    window.addEventListener('resize', syncBlackMirrorScene);
    media.addEventListener('change', syncBlackMirrorScene);
  })();
</script>

<script is:inline>
  (() => {
    const canvas = document.querySelector('.theme-scene-protoss-canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext('2d', { alpha: true });
    if (!context) return;

    const root = document.documentElement;
    const media = window.matchMedia('(prefers-reduced-motion: reduce)');
    const cyan = '108, 214, 255';
    const blue = '74, 144, 226';

    class ProtossNode {
      constructor(width, height) {
        this.width = width;
        this.height = height;
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.size = Math.random() * 3 + 4;
        this.fieldRadius = Math.random() * 100 + 150;
        this.phase = Math.random() * Math.PI * 2;
      }

      draw(time) {
        const fieldScale = 0.9 + Math.sin(time * 2 + this.phase) * 0.1;
        const aura = context.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.fieldRadius * fieldScale);
        aura.addColorStop(0, `rgba(${cyan}, 0.036)`);
        aura.addColorStop(0.5, `rgba(${blue}, 0.014)`);
        aura.addColorStop(1, `rgba(${blue}, 0)`);
        context.beginPath();
        context.arc(this.x, this.y, this.fieldRadius * fieldScale, 0, Math.PI * 2);
        context.fillStyle = aura;
        context.fill();

        context.save();
        context.translate(this.x, this.y);
        context.rotate(time * 0.5);
        context.beginPath();
        context.moveTo(0, -this.size * 1.5);
        context.lineTo(this.size, 0);
        context.lineTo(0, this.size * 1.5);
        context.lineTo(-this.size, 0);
        context.closePath();
        context.fillStyle = 'rgba(228, 190, 89, 0.82)';
        context.shadowColor = `rgba(${cyan}, 0.5)`;
        context.shadowBlur = 8;
        context.fill();
        context.restore();
      }
    }

    class ProtossBeam {
      constructor(width, height) {
        this.width = width;
        this.height = height;
        this.reset();
      }

      reset() {
        this.x = Math.random() * this.width;
        this.y = Math.random() * this.height;
        this.heightValue = 0;
        this.maxHeight = Math.random() * 300 + 100;
        this.widthValue = Math.random() * 2 + 1;
        this.life = 0;
        this.maxLife = Math.random() * 60 + 60;
        this.stage = 'growing';
        this.color = Math.random() > 0.3 ? cyan : blue;
      }

      update() {
        this.life += 1;

        if (this.stage === 'growing') {
          this.heightValue += 15;
          if (this.heightValue >= this.maxHeight) this.stage = 'holding';
          return;
        }

        if (this.stage === 'holding') {
          if (this.life > this.maxLife - 20) this.stage = 'shrinking';
          return;
        }

        this.heightValue -= 15;
        if (this.heightValue <= 0) this.reset();
      }

      draw() {
        if (this.heightValue <= 0) return;

        const fade = 0.44 * Math.min(1, this.life / 20, (this.maxLife - this.life) / 20);
        const shaft = context.createLinearGradient(this.x, this.y, this.x, this.y - this.heightValue);
        shaft.addColorStop(0, `rgba(${this.color}, 0)`);
        shaft.addColorStop(0.5, `rgba(${this.color}, ${fade})`);
        shaft.addColorStop(1, `rgba(${this.color}, 0)`);

        context.beginPath();
        context.rect(
          this.x - this.widthValue / 2,
          this.y - this.heightValue,
          this.widthValue,
          this.heightValue * 2,
        );
        context.fillStyle = shaft;
        context.fill();

        context.beginPath();
        context.moveTo(this.x, this.y + this.heightValue / 2);
        context.lineTo(this.x, this.y - this.heightValue / 2);
        context.strokeStyle = `rgba(255, 255, 255, ${fade * 0.55})`;
        context.lineWidth = 0.5;
        context.stroke();
      }
    }

    let width = 0;
    let height = 0;
    let rafId = 0;
    let time = 0;
    let nodes = [];
    let beams = [];

    const isProtossTheme = () =>
      root.classList.contains('protoss') || root.getAttribute('data-theme') === 'protoss';

    const resizeCanvas = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(window.innerWidth, document.documentElement.clientWidth);
      height = Math.max(window.innerHeight, document.documentElement.clientHeight);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const rebuildScene = () => {
      const nodeCount = Math.max(Math.floor((width * height) / 150000), 4);
      nodes = Array.from({ length: nodeCount }, () => new ProtossNode(width, height));
      beams = Array.from({ length: 11 }, () => new ProtossBeam(width, height));
    };

    const clearCanvas = () => {
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.clearRect(0, 0, canvas.width, canvas.height);
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const drawLinks = () => {
      context.beginPath();
      for (let i = 0; i < nodes.length; i += 1) {
        for (let j = i + 1; j < nodes.length; j += 1) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          if (distance >= 400) continue;

          const alpha = (1 - distance / 400) * 0.3;
          context.moveTo(nodes[i].x, nodes[i].y);
          context.lineTo(nodes[j].x, nodes[j].y);
          context.strokeStyle = `rgba(${cyan}, ${alpha})`;
          context.lineWidth = 1;
        }
      }
      context.stroke();
    };

    const drawStaticFrame = () => {
      clearCanvas();
      nodes.forEach((node) => node.draw(0));
      drawLinks();
      beams.forEach((beam) => {
        beam.heightValue = beam.maxHeight * 0.7;
        beam.life = beam.maxLife * 0.5;
        beam.draw();
      });
    };

    const drawFrame = () => {
      if (!isProtossTheme()) {
        rafId = 0;
        clearCanvas();
        return;
      }

      time += 0.01;
      clearCanvas();
      nodes.forEach((node) => node.draw(time));
      drawLinks();
      beams.forEach((beam) => {
        beam.update();
        beam.draw();
      });
      rafId = window.requestAnimationFrame(drawFrame);
    };

    const syncProtossScene = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }

      if (!isProtossTheme()) {
        clearCanvas();
        return;
      }

      resizeCanvas();
      rebuildScene();
      time = 0;

      if (media.matches) {
        drawStaticFrame();
        return;
      }

      drawFrame();
    };

    resizeCanvas();
    syncProtossScene();

    const observer = new MutationObserver(syncProtossScene);
    observer.observe(root, {
      attributes: true,
      attributeFilter: ['class', 'data-theme'],
    });

    window.addEventListener('resize', syncProtossScene);
    media.addEventListener('change', syncProtossScene);
  })();
</script>

<script is:inline>
  (() => {
    const canvas = document.querySelector('.theme-scene-evomap-canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext('2d', { alpha: true });
    if (!context) return;

    const root = document.documentElement;
    const media = window.matchMedia('(prefers-reduced-motion: reduce)');
    const supportedThemes = new Set([
      'evolution',
      'cyberpunk',
      'zerg',
      'terran',
      'mechanicus',
      'threebody',
      'zimablue',
      'westworld',
      'poi',
    ]);

    const pick = (items) => items[Math.floor(Math.random() * items.length)];
    const rand = (min, max) => min + Math.random() * (max - min);
    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
    const randEdgePoint = (inset = 92, band = 120) => {
      const side = Math.floor(rand(0, 4));
      switch (side) {
        case 0:
          return { x: rand(-band, width + band), y: rand(-band, inset) };
        case 1:
          return { x: rand(width - inset, width + band), y: rand(-band, height + band) };
        case 2:
          return { x: rand(-band, width + band), y: rand(height - inset, height + band) };
        default:
          return { x: rand(-band, inset), y: rand(-band, height + band) };
      }
    };
    let width = 0;
    let height = 0;
    let dpr = 1;
    let rafId = 0;
    let state = null;
    let currentTheme = '';
    let time = 0;

    const getCurrentTheme = () => {
      const explicit = root.getAttribute('data-theme');
      if (explicit && supportedThemes.has(explicit)) return explicit;
      for (const theme of supportedThemes) {
        if (root.classList.contains(theme)) return theme;
      }
      return '';
    };

    const resizeCanvas = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(window.innerWidth, document.documentElement.clientWidth);
      height = Math.max(window.innerHeight, document.documentElement.clientHeight);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const clearCanvas = () => {
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.clearRect(0, 0, canvas.width, canvas.height);
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const drawGrid = (stepX, stepY, color, offsetX = 0, offsetY = 0) => {
      context.beginPath();
      for (let x = (-offsetX % stepX) - stepX; x <= width + stepX; x += stepX) {
        context.moveTo(x, 0);
        context.lineTo(x, height);
      }
      for (let y = (-offsetY % stepY) - stepY; y <= height + stepY; y += stepY) {
        context.moveTo(0, y);
        context.lineTo(width, y);
      }
      context.strokeStyle = color;
      context.lineWidth = 1;
      context.stroke();
    };

    const drawHexGrid = (size, color, alpha, drift = 0) => {
      const hexHeight = Math.sqrt(3) * size;
      const hexWidth = size * 2;
      const verticalStep = hexHeight;
      const horizontalStep = size * 1.5;
      context.beginPath();
      for (let row = -1; row <= Math.ceil(height / verticalStep) + 1; row += 1) {
        const y = row * verticalStep + (drift % verticalStep);
        const rowOffset = row % 2 === 0 ? 0 : horizontalStep / 2;
        for (let col = -1; col <= Math.ceil(width / horizontalStep) + 1; col += 1) {
          const x = col * horizontalStep + rowOffset;
          context.moveTo(x + size * 0.5, y);
          context.lineTo(x + size * 1.5, y);
          context.lineTo(x + hexWidth, y + hexHeight / 2);
          context.lineTo(x + size * 1.5, y + hexHeight);
          context.lineTo(x + size * 0.5, y + hexHeight);
          context.lineTo(x, y + hexHeight / 2);
          context.closePath();
        }
      }
      context.strokeStyle = color;
      context.globalAlpha = alpha;
      context.lineWidth = 1;
      context.stroke();
      context.globalAlpha = 1;
    };

    const drawBracketRect = (x, y, w, h, color, alpha = 1) => {
      const arm = Math.max(10, Math.min(w, h) * 0.22);
      context.save();
      context.strokeStyle = color;
      context.globalAlpha = alpha;
      context.lineWidth = 1.2;
      context.beginPath();
      context.moveTo(x, y + arm);
      context.lineTo(x, y);
      context.lineTo(x + arm, y);
      context.moveTo(x + w - arm, y);
      context.lineTo(x + w, y);
      context.lineTo(x + w, y + arm);
      context.moveTo(x + w, y + h - arm);
      context.lineTo(x + w, y + h);
      context.lineTo(x + w - arm, y + h);
      context.moveTo(x + arm, y + h);
      context.lineTo(x, y + h);
      context.lineTo(x, y + h - arm);
      context.stroke();
      context.restore();
    };

    const drawReticle = (x, y, radius, color, alpha = 1) => {
      context.save();
      context.strokeStyle = color;
      context.globalAlpha = alpha;
      context.lineWidth = 1;
      context.beginPath();
      context.arc(x, y, radius, 0, Math.PI * 2);
      context.moveTo(x - radius - 10, y);
      context.lineTo(x - radius / 2, y);
      context.moveTo(x + radius / 2, y);
      context.lineTo(x + radius + 10, y);
      context.moveTo(x, y - radius - 10);
      context.lineTo(x, y - radius / 2);
      context.moveTo(x, y + radius / 2);
      context.lineTo(x, y + radius + 10);
      context.stroke();
      context.restore();
    };

    const drawLabel = (text, x, y, color, align = 'left', alpha = 1, size = 12) => {
      context.save();
      context.fillStyle = color;
      context.globalAlpha = alpha;
      context.font = `${size}px "JetBrains Mono", "SF Mono", monospace`;
      context.textAlign = align;
      context.textBaseline = 'middle';
      context.fillText(text, x, y);
      context.restore();
    };

    const drawGlow = (x, y, radius, innerColor, outerColor = 'rgba(0, 0, 0, 0)') => {
      const gradient = context.createRadialGradient(x, y, 0, x, y, radius);
      gradient.addColorStop(0, innerColor);
      gradient.addColorStop(1, outerColor);
      context.beginPath();
      context.arc(x, y, radius, 0, Math.PI * 2);
      context.fillStyle = gradient;
      context.fill();
    };

    const drawGear = (x, y, radius, teeth, rotation, stroke, fillAlpha = 0) => {
      context.save();
      context.translate(x, y);
      context.rotate(rotation);
      context.beginPath();
      for (let i = 0; i < teeth * 2; i += 1) {
        const angle = (Math.PI * i) / teeth;
        const r = i % 2 === 0 ? radius : radius * 0.8;
        const px = Math.cos(angle) * r;
        const py = Math.sin(angle) * r;
        if (i === 0) {
          context.moveTo(px, py);
        } else {
          context.lineTo(px, py);
        }
      }
      context.closePath();
      context.strokeStyle = stroke;
      context.fillStyle = `rgba(255, 255, 255, ${fillAlpha})`;
      context.lineWidth = 1.2;
      if (fillAlpha > 0) context.fill();
      context.stroke();

      context.beginPath();
      context.arc(0, 0, radius * 0.38, 0, Math.PI * 2);
      context.stroke();
      context.restore();
    };

    const makeEvolutionState = () => ({
      particles: Array.from(
        { length: Math.max(44, Math.round((width * height) / 76000)) },
        () => ({
          x: rand(0, width),
          y: rand(0, height),
          vx: rand(-0.16, 0.16),
          vy: rand(-0.14, 0.14),
          radius: rand(2, 4.8),
          color: pick([
            [105, 174, 252],
            [45, 212, 191],
            [244, 114, 182],
            [129, 140, 248],
          ]),
        }),
      ),
    });

    const makeCyberpunkState = () => ({
      markers: Array.from({ length: 30 }, () => ({
        x: rand(60, Math.max(100, width - 160)),
        y: rand(60, Math.max(100, height - 180)),
        w: rand(46, 120),
        h: rand(24, 64),
        type: pick(['solid', 'cross', 'bracket']),
      })),
    });

    const makeZergState = () => ({
      blobs: Array.from({ length: Math.max(12, Math.round(width / 140)) }, () => {
        const point = randEdgePoint(120, 90);
        return {
        x: point.x,
        y: point.y,
        radius: rand(42, 96),
        speed: rand(0.45, 1.2),
        drift: rand(-0.16, 0.16),
        phase: rand(0, Math.PI * 2),
        color: pick([
          '219, 39, 119',
          '192, 38, 211',
          '168, 85, 247',
          '244, 114, 182',
        ]),
        trail: [],
      };
      }),
    });

    const makeTerranState = () => ({
      reticles: Array.from({ length: 12 }, () => {
        const point = randEdgePoint(140, 80);
        return {
        x: clamp(point.x, 72, Math.max(72, width - 72)),
        y: clamp(point.y, 72, Math.max(72, height - 72)),
        radius: rand(18, 42),
        pulse: rand(0, Math.PI * 2),
      };
      }),
    });

    const makeMechanicusState = () => ({
      gears: [
        { x: width * 0.18, y: height * 0.24, radius: 44, teeth: 12, speed: 0.34, phase: 0.2 },
        { x: width * 0.78, y: height * 0.2, radius: 58, teeth: 14, speed: -0.22, phase: 1.2 },
        { x: width * 0.72, y: height * 0.72, radius: 78, teeth: 18, speed: 0.12, phase: 2.3 },
        { x: width * 0.24, y: height * 0.76, radius: 32, teeth: 10, speed: -0.28, phase: 0.6 },
      ],
      columns: Array.from({ length: Math.max(18, Math.floor(width / 32)) }, (_, index) => ({
        x: index * (width / Math.max(18, Math.floor(width / 32))) + rand(-6, 6),
        y: rand(-height, height),
        speed: rand(0.8, 1.8),
      })),
    });

    const makeThreeBodyState = () => ({
      stars: Array.from({ length: 84 }, () => ({
        x: rand(0, width),
        y: rand(0, height),
        radius: rand(0.5, 1.8),
        alpha: rand(0.24, 0.8),
      })),
      trails: [[], [], []],
    });

    const makeZimaBlueState = () => ({
      particles: Array.from({ length: Math.min(Math.floor((width * height) / 2600), 260) }, () => {
        const size = Math.random();
        const angle = rand(0, Math.PI * 2);
        const speed = (1.05 - size) * 0.12 + 0.02;
        return {
          x: rand(0, width),
          y: rand(0, height),
          size,
          radius: size < 0.7 ? rand(0.2, 1.0) : size < 0.95 ? rand(0.8, 2.0) : rand(1.2, 3.0),
          alpha: size < 0.7 ? rand(0.1, 0.4) : size < 0.95 ? rand(0.3, 0.7) : rand(0.55, 0.9),
          phase: rand(0, Math.PI * 2),
          speed: rand(0.15, 0.65),
          isBright: size > 0.92,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
        };
      }),
      beams: Array.from({ length: 12 }, (_, index) => ({
        angle: (index / 12) * Math.PI * 2,
        offset: rand(0.7, 1.3),
        width: rand(7, 12),
      })),
      orbs: Array.from({ length: 8 }, (_, index) => ({
        angle: (index / 8) * Math.PI * 2,
        radius: rand(52, 88),
        spread: rand(74, 108),
        phase: rand(0, Math.PI * 2),
      })),
    });

    const makeWestworldState = () => ({
      dots: Array.from({ length: Math.min(Math.floor((width * height) / 9000), 120) }, () => ({
        x: rand(0, width),
        y: rand(0, height),
        vx: rand(-0.16, 0.16),
        vy: rand(-0.16, 0.16),
        radius: rand(0.8, 2.4),
        alpha: rand(0.15, 0.45),
        phase: rand(0, Math.PI * 2),
      })),
    });

    const makePoiState = () => ({
      tracks: Array.from({ length: 12 }, () => {
        const w = rand(68, 130);
        const h = rand(42, 92);
        const point = randEdgePoint(150, 110);
        return {
        x: clamp(point.x, 20, Math.max(20, width - w - 20)),
        y: clamp(point.y, 60, Math.max(60, height - h - 20)),
