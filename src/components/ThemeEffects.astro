      <circle class="network-node network-node--dim" cx="1386" cy="728" r="2.3" style="animation-delay:-3.4s" />
      <circle class="network-node" cx="1514" cy="616" r="2.8" style="animation-delay:-2.1s" />
      <circle class="network-node network-node--cool" cx="1282" cy="822" r="2.9" style="animation-delay:-4.3s" />
