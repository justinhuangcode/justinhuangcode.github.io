        gradient.addColorStop(1, 'rgba(55, 192, 246, 0)');
        context.beginPath();
        context.moveTo(centerX + normalX * 0.25, centerY + normalY * 0.25);
        context.lineTo(centerX - normalX * 0.25, centerY - normalY * 0.25);
        context.lineTo(endX - normalX, endY - normalY);
        context.lineTo(endX + normalX, endY + normalY);
        context.closePath();
        context.fillStyle = gradient;
        context.fill();
      });
      context.restore();

      [
        { spreadX: 1.6, spreadY: 0.22, alpha: 0.03, color: '20, 60, 120' },
        { spreadX: 1.2, spreadY: 0.22, alpha: 0.05, color: '30, 100, 160' },
        { spreadX: 0.85, spreadY: 0.22, alpha: 0.08, color: '55, 192, 246' },
