        h,
        vx: rand(-0.45, 0.45),
        vy: rand(-0.32, 0.32),
        status: pick(['IRRELEVANT', 'RELEVANT', 'THREAT']),
      };
      }),
    });

    const createState = (theme) => {
      switch (theme) {
        case 'evolution':
          return makeEvolutionState();
        case 'cyberpunk':
          return makeCyberpunkState();
        case 'zerg':
          return makeZergState();
        case 'terran':
          return makeTerranState();
        case 'mechanicus':
          return makeMechanicusState();
        case 'threebody':
          return makeThreeBodyState();
        case 'zimablue':
          return makeZimaBlueState();
        case 'westworld':
          return makeWestworldState();
        case 'poi':
          return makePoiState();
        default:
          return null;
      }
    };

    const drawEvolution = (scene, phase, animate) => {
      drawGlow(width * 0.14, height * 0.14, 220, 'rgba(84, 162, 255, 0.14)');
      drawGlow(width * 0.84, height * 0.18, 250, 'rgba(45, 212, 191, 0.11)');
      drawGlow(width * 0.58, height * 0.08, 280, 'rgba(244, 114, 182, 0.06)');
      drawGlow(width * 0.56, height * 0.72, 260, 'rgba(99, 102, 241, 0.045)');
      drawGlow(width * 0.48, height * 0.26, 380, 'rgba(84, 162, 255, 0.065)');
      drawGlow(width * 0.72, height * 0.46, 320, 'rgba(45, 212, 191, 0.045)');
      const anchors = [
        { x: width * 0.08, y: height * 0.22, color: '84, 162, 255' },
        { x: width * 0.9, y: height * 0.18, color: '45, 212, 191' },
        { x: width * 0.88, y: height * 0.58, color: '244, 114, 182' },
        { x: width * 0.14, y: height * 0.76, color: '129, 140, 248' },
        { x: width * 0.54, y: height * 0.9, color: '84, 162, 255' },
      ];

