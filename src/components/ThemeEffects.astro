          if (particle.x > width + 6) particle.x -= width + 12;
          if (particle.y < -6) particle.y += height + 12;
          if (particle.y > height + 6) particle.y -= height + 12;
        }
        const pulse = Math.sin(phase * particle.speed + particle.phase);
        const alpha = particle.alpha + pulse * 0.15;
        if (alpha <= 0) return;
        if (particle.isBright) {
          const glowRadius = particle.radius * 4;
          const glow = context.createRadialGradient(particle.x, particle.y, 0, particle.x, particle.y, glowRadius);
          glow.addColorStop(0, `rgba(200, 220, 255, ${alpha * 0.8})`);
          glow.addColorStop(0.3, `rgba(180, 210, 255, ${alpha * 0.3})`);
          glow.addColorStop(1, 'rgba(180, 210, 255, 0)');
          context.fillStyle = glow;
          context.fillRect(particle.x - glowRadius, particle.y - glowRadius, glowRadius * 2, glowRadius * 2);
        }
        context.beginPath();
        context.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
        context.fillStyle = `rgba(210, 225, 245, ${alpha})`;
        context.fill();
      });

      context.save();
      context.globalCompositeOperation = 'screen';
      scene.beams.forEach((beam, index) => {
        const angle = beam.angle + Math.sin(phase * 0.05 + index * 1.1) * 0.08;
        const radius = Math.max(width, height) * 0.6;
        const endX = centerX + Math.cos(angle) * radius;
        const endY = centerY + Math.sin(angle) * radius;
        const normalX = Math.cos(angle + Math.PI / 2) * beam.width;
        const normalY = Math.sin(angle + Math.PI / 2) * beam.width;
        const alpha = 0.012 + Math.sin(phase * 0.09 + index * 0.6) * 0.006;
        const gradient = context.createLinearGradient(centerX, centerY, endX, endY);
        gradient.addColorStop(0, `rgba(55, 192, 246, ${alpha * 2})`);
