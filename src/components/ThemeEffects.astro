      <circle class="network-node network-node--cool" cx="1028" cy="118" r="3.1" style="animation-delay:-0.8s" />
      <circle class="network-node" cx="1162" cy="246" r="2.8" style="animation-delay:-1.7s" />
      <circle class="network-node network-node--dim" cx="1338" cy="174" r="2.2" style="animation-delay:-2.8s" />
