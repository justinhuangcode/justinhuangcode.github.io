        radial.addColorStop(0.6, `rgba(${layer.color}, ${layer.alpha * 0.4})`);
        radial.addColorStop(1, `rgba(${layer.color}, 0)`);
        context.fillStyle = radial;
        context.fillRect(-1, -1, 2, 2);
        context.restore();
      });

      context.save();
      context.globalCompositeOperation = 'screen';
      scene.orbs.forEach((orb, index) => {
        const angle = orb.angle + phase * 0.02 + orb.phase * 0.05;
        const x = centerX + Math.cos(angle) * orb.radius * 2.5;
        const y = centerY + Math.sin(angle) * orb.radius * 0.4;
        const radius = orb.spread + Math.sin(phase * 0.1 + index) * 20;
        const alpha = 0.02 + Math.sin(phase * 0.06 + index * 0.7) * 0.01;
        const radial = context.createRadialGradient(x, y, 0, x, y, radius);
        radial.addColorStop(0, `rgba(55, 192, 246, ${alpha})`);
        radial.addColorStop(1, 'rgba(55, 192, 246, 0)');
        context.fillStyle = radial;
        context.fillRect(x - radius, y - radius, radius * 2, radius * 2);
      });
      context.restore();

      const coreSize = Math.min(width, height) * 0.06 * (1 + Math.sin(phase * 0.25) * 0.03);
      const haloRadius = coreSize * 2.5;
      const halo = context.createRadialGradient(centerX, centerY, coreSize * 0.3, centerX, centerY, haloRadius);
      halo.addColorStop(0, `rgba(55, 192, 246, ${0.16 + Math.sin(phase * 0.25) * 0.05})`);
      halo.addColorStop(0.5, 'rgba(55, 192, 246, 0.04)');
      halo.addColorStop(1, 'rgba(55, 192, 246, 0)');
      context.save();
      context.globalCompositeOperation = 'screen';
      context.fillStyle = halo;
      context.fillRect(centerX - haloRadius, centerY - haloRadius, haloRadius * 2, haloRadius * 2);
      context.restore();

      context.beginPath();
      if (typeof context.roundRect === 'function') {
        context.roundRect(centerX - coreSize / 2, centerY - coreSize / 2, coreSize, coreSize, coreSize * 0.08);
      } else {
        context.rect(centerX - coreSize / 2, centerY - coreSize / 2, coreSize, coreSize);
      }
      context.fillStyle = 'rgba(55, 192, 246, 0.78)';
      context.fill();
      context.strokeStyle = 'rgba(170, 225, 255, 0.95)';
      context.lineWidth = 1;
      context.stroke();

      const vignette = context.createRadialGradient(centerX, centerY, width * 0.15, centerX, centerY, width * 0.9);
      vignette.addColorStop(0, 'rgba(0, 0, 0, 0)');
      vignette.addColorStop(0.5, 'rgba(0, 0, 0, 0.1)');
      vignette.addColorStop(1, 'rgba(0, 2, 8, 0.65)');
      context.fillStyle = vignette;
      context.fillRect(0, 0, width, height);

      const fade = context.createLinearGradient(0, 0, 0, height);
      fade.addColorStop(0, 'rgba(0, 2, 10, 0.4)');
      fade.addColorStop(0.3, 'rgba(0, 0, 0, 0)');
      fade.addColorStop(0.7, 'rgba(0, 0, 0, 0)');
      fade.addColorStop(1, 'rgba(0, 2, 10, 0.5)');
      context.fillStyle = fade;
      context.fillRect(0, 0, width, height);
    };

    const drawWestworld = (scene, phase, animate) => {
      const background = context.createLinearGradient(0, 0, 0, height);
      background.addColorStop(0, '#f8fbff');
      background.addColorStop(1, '#e9eef6');
      context.fillStyle = background;
      context.fillRect(0, 0, width, height);

      if (animate) {
        scene.dots.forEach((dot) => {
          dot.x += dot.vx;
          dot.y += dot.vy;
          if (dot.x < 0 || dot.x > width) dot.vx *= -1;
          if (dot.y < 0 || dot.y > height) dot.vy *= -1;
        });
      }

      context.strokeStyle = 'rgba(180, 200, 215, 0.04)';
      context.lineWidth = 0.5;
      for (let x = 0; x < width; x += 60) {
        context.beginPath();
        context.moveTo(x, 0);
        context.lineTo(x, height);
        context.stroke();
      }
      for (let y = 0; y < height; y += 60) {
        context.beginPath();
        context.moveTo(0, y);
        context.lineTo(width, y);
        context.stroke();
      }

      const centerX = width * 0.5;
      const centerY = height * 0.45;
      const scale = Math.min(width, height) * 0.18;
      const stretch = 1 + Math.sin(phase * 0.2) * 0.02;
      context.save();
      context.globalAlpha = 0.03;
      context.strokeStyle = 'rgba(100, 150, 175, 1)';
      context.lineWidth = 0.5;
      const spine = [-1.6, -1.2, -0.8, -0.4, 0, 0.3, 0.6, 0.9, 1.2];
      context.beginPath();
      spine.forEach((offset, index) => {
        const x = centerX;
        const y = centerY + offset * scale * stretch;
        if (index === 0) {
          context.moveTo(x, y);
        } else {
          context.lineTo(x, y);
        }
      });
      context.stroke();
      [
        [-0.5, -1, 0.5, -1],
        [-0.7, -0.6, 0.7, -0.6],
        [-0.8, -0.2, 0.8, -0.2],
        [-0.7, 0.2, 0.7, 0.2],
        [-0.4, 0.6, 0.4, 0.6],
      ].forEach(([x1, y1, x2, y2]) => {
        context.beginPath();
        context.moveTo(centerX + x1 * scale, centerY + y1 * scale * stretch);
        context.lineTo(centerX + x2 * scale, centerY + y2 * scale * stretch);
        context.stroke();
      });
      [
        { offsetY: -1.6, radiusX: 0.15, radiusY: 0.1 },
        { offsetY: -0.2, radiusX: 0.4, radiusY: 0.55 },
      ].forEach(({ offsetY, radiusX, radiusY }) => {
        context.beginPath();
        context.ellipse(centerX, centerY + offsetY * scale * stretch, radiusX * scale, radiusY * scale, 0, 0, Math.PI * 2);
        context.stroke();
      });
      context.restore();

      for (let i = 0; i < scene.dots.length; i += 1) {
        for (let j = i + 1; j < scene.dots.length; j += 1) {
          const a = scene.dots[i];
          const b = scene.dots[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          if (distance > 160) continue;
          context.beginPath();
          context.moveTo(a.x, a.y);
          context.lineTo(b.x, b.y);
          context.strokeStyle = `rgba(160, 185, 205, ${(1 - distance / 160) * 0.08})`;
          context.lineWidth = 0.5;
          context.stroke();
        }
      }

      scene.dots.forEach((dot) => {
        const alpha = dot.alpha + Math.sin(phase * 0.4 + dot.phase) * 0.1;
        if (alpha <= 0) return;
        context.beginPath();
        context.arc(dot.x, dot.y, dot.radius, 0, Math.PI * 2);
        context.fillStyle = `rgba(120, 160, 190, ${alpha})`;
        context.fill();
        if (dot.radius > 1.8) {
          const glowRadius = dot.radius * 5;
          const glow = context.createRadialGradient(dot.x, dot.y, 0, dot.x, dot.y, glowRadius);
          glow.addColorStop(0, `rgba(60, 155, 185, ${alpha * 0.3})`);
          glow.addColorStop(1, 'rgba(60, 155, 185, 0)');
          context.fillStyle = glow;
          context.fillRect(dot.x - glowRadius, dot.y - glowRadius, glowRadius * 2, glowRadius * 2);
        }
      });

      const scanY = ((phase * 22) % (height + 180)) - 90;
      const scan = context.createLinearGradient(0, scanY - 40, 0, scanY + 40);
      scan.addColorStop(0, 'rgba(60, 155, 185, 0)');
      scan.addColorStop(0.5, 'rgba(60, 155, 185, 0.06)');
      scan.addColorStop(1, 'rgba(60, 155, 185, 0)');
      context.fillStyle = scan;
      context.fillRect(0, scanY - 40, width, 80);
    };

    const drawPoi = (scene, phase, animate) => {
      context.fillStyle = '#030303';
      context.fillRect(0, 0, width, height);
      drawGrid(68, 68, 'rgba(194, 164, 82, 0.028)');
      drawGlow(width * 0.5, height * 0.5, 260, 'rgba(194, 164, 82, 0.028)');

      const centerX = width * 0.5;
      const centerY = height * 0.5;
      drawReticle(centerX, centerY, 42, 'rgba(194, 164, 82, 0.14)', 1);
      drawReticle(centerX, centerY, 92, 'rgba(194, 164, 82, 0.055)', 1);
      drawReticle(centerX, centerY, 148, 'rgba(194, 164, 82, 0.028)', 1);

      drawLabel('YOU ARE BEING WATCHED', 34, 28, '#bfa056', 'left', 0.56, 12);
      drawLabel('SYSTEM 001', width - 34, 28, '#8c8c8c', 'right', 0.4, 11);
      drawLabel(`SCAN ${String(Math.floor((phase * 100) % 999)).padStart(3, '0')}`, 34, 50, '#8d8d8d', 'left', 0.42, 11);
      drawLabel('SOCIAL SECURITY // ACTIVE', width - 34, 50, '#5f5f5f', 'right', 0.38, 11);

      for (let y = 92; y < height; y += 96) {
        context.beginPath();
        context.moveTo(width - 72, y);
        context.lineTo(width - 24, y);
        context.strokeStyle = 'rgba(194, 164, 82, 0.05)';
        context.lineWidth = 1;
        context.stroke();
      }

      scene.tracks.forEach((track, index) => {
        if (animate) {
          track.x += track.vx;
          track.y += track.vy;
          if (track.x < 20 || track.x + track.w > width - 20) track.vx *= -1;
          if (track.y < 60 || track.y + track.h > height - 20) track.vy *= -1;
        }

        const color =
          track.status === 'THREAT'
            ? 'rgba(248, 113, 113, 0.86)'
            : track.status === 'RELEVANT'
              ? 'rgba(194, 164, 82, 0.72)'
              : 'rgba(163, 163, 163, 0.5)';

        drawBracketRect(track.x, track.y, track.w, track.h, color, 1);
        drawLabel(track.status, track.x, track.y - 10, color.replace('0.86', '1').replace('0.5', '1'), 'left', 0.9, 11);
        drawLabel(`#${String(index + 1).padStart(2, '0')}`, track.x + track.w, track.y - 10, '#737373', 'right', 0.7, 10);

        if (track.status !== 'IRRELEVANT') {
          context.beginPath();
          context.moveTo(track.x + track.w / 2, track.y + track.h / 2);
          context.lineTo(centerX, centerY);
          context.strokeStyle = color.replace('0.86', '0.24').replace('0.5', '0.14');
          context.lineWidth = 1;
          context.stroke();
        }
      });

      context.beginPath();
      context.moveTo(centerX - 220, centerY);
      context.lineTo(centerX + 220, centerY);
      context.moveTo(centerX, centerY - 220);
      context.lineTo(centerX, centerY + 220);
      context.strokeStyle = 'rgba(194, 164, 82, 0.04)';
      context.lineWidth = 1;
      context.stroke();

      if (Math.sin(phase * 6) > 0.9) {
        context.fillStyle = 'rgba(194, 164, 82, 0.02)';
        context.fillRect(0, height * 0.32, width, 18);
      }
    };

    const renderScene = (theme, scene, phase, animate) => {
      switch (theme) {
        case 'evolution':
          drawEvolution(scene, phase, animate);
          break;
        case 'cyberpunk':
          drawCyberpunk(scene, phase);
          break;
        case 'zerg':
          drawZerg(scene, phase, animate);
          break;
        case 'terran':
          drawTerran(scene, phase);
          break;
        case 'mechanicus':
          drawMechanicus(scene, phase, animate);
          break;
        case 'threebody':
          drawThreeBody(scene, phase, animate);
          break;
        case 'zimablue':
          drawZimaBlue(scene, phase, animate);
          break;
        case 'westworld':
          drawWestworld(scene, phase, animate);
          break;
        case 'poi':
          drawPoi(scene, phase, animate);
          break;
        default:
          break;
      }
    };

    const drawFrame = () => {
      if (getCurrentTheme() !== currentTheme || !state) {
        syncScene();
        return;
      }

      time += 0.016;
      clearCanvas();
      renderScene(currentTheme, state, time, true);
      rafId = window.requestAnimationFrame(drawFrame);
    };

    const syncScene = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }

      currentTheme = getCurrentTheme();
      clearCanvas();

      if (!currentTheme) return;

      resizeCanvas();
      state = createState(currentTheme);
      time = 0;

      if (!state) return;

      if (media.matches) {
        renderScene(currentTheme, state, time, false);
        return;
      }

      drawFrame();
    };

    resizeCanvas();
    syncScene();

    const observer = new MutationObserver(syncScene);
    observer.observe(root, {
      attributes: true,
      attributeFilter: ['class', 'data-theme'],
    });

    window.addEventListener('resize', syncScene);
    media.addEventListener('change', syncScene);
  })();
</script>
