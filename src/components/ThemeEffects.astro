    </svg>
  </div>
  <div class="theme-scene-network theme-scene-network-b">
    <svg viewBox="0 0 1600 1200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <path class="network-line network-line--soft" d="M612 92 L770 208 L926 102" />
      <path class="network-line network-line--bright" d="M770 208 L834 370 L980 302" />
      <path class="network-line network-line--soft" d="M672 538 L846 646 L1024 560" />
      <path class="network-line network-line--bright" d="M846 646 L932 824 L1086 756" />
      <path class="network-line network-line--soft" d="M1252 888 L1390 986 L1516 876" />
