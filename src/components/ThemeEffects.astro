  @keyframes cyberpunk-pulse {
    0% { opacity: 0.5; }
    50% { opacity: 0.95; }
    100% { opacity: 0.55; }
  }

  @keyframes cyberpunk-scan {
    0% { transform: translateY(-6%); }
    100% { transform: translateY(6%); }
  }

  @keyframes evo-drift {
    0% { transform: translate3d(-1.5%, -1%, 0) scale(1); }
    100% { transform: translate3d(1.5%, 1%, 0) scale(1.04); }
  }

  @keyframes evo-svg-drift-a {
    0% { transform: translate3d(-1.2%, -1%, 0) scale(1); opacity: 0.82; }
    100% { transform: translate3d(1.4%, 1.1%, 0) scale(1.02); opacity: 1; }
  }

  @keyframes evo-svg-drift-b {
    0% { transform: translate3d(1%, -0.8%, 0) scale(0.995); opacity: 0.64; }
    100% { transform: translate3d(-1.25%, 1.25%, 0) scale(1.025); opacity: 0.92; }
  }

  @keyframes evo-pulse {
    0% { opacity: 0.5; }
    100% { opacity: 0.95; }
  }

  @keyframes evo-dash {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -240; }
  }

  @keyframes evo-dash-reverse {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 240; }
  }

  @keyframes evo-line-fade {
    0% { opacity: 0.18; }
    50% { opacity: 0.6; }
    100% { opacity: 0.26; }
  }

  @keyframes evo-grid-shift {
    0% { background-position: 0 0, 0 0, 0 0, 0 0; }
    100% { background-position: 44px 44px, -44px 44px, 8px -6px, -10px 12px; }
  }

  @keyframes evo-lattice {
    0% { transform: translate3d(-1%, -1%, 0); opacity: 0.34; }
    50% { opacity: 0.68; }
    100% { transform: translate3d(1.5%, 1.5%, 0); opacity: 0.42; }
  }

  @keyframes evo-network-drift {
    0% { transform: translate3d(-1.5%, -1%, 0); opacity: 0.28; }
    50% { opacity: 0.58; }
    100% { transform: translate3d(1.75%, 1.2%, 0); opacity: 0.36; }
  }

  @keyframes evo-network-float {
    0% { transform: translate3d(-1%, 0.5%, 0) scale(1); opacity: 0.22; }
    100% { transform: translate3d(1.5%, -1.2%, 0) scale(1.03); opacity: 0.48; }
  }

  @keyframes evo-orbit {
    0% { transform: translate3d(-2%, -1%, 0) scale(0.98); opacity: 0.42; }
    100% { transform: translate3d(2%, 1.5%, 0) scale(1.08); opacity: 0.78; }
  }

  @keyframes evo-sweep {
    0% { background-position: 0% 0%, 100% 100%; opacity: 0.2; }
    50% { opacity: 0.62; }
    100% { background-position: 100% 100%, 0% 0%; opacity: 0.28; }
  }

  @keyframes evo-twinkle {
    0% { opacity: 0.12; }
    50% { opacity: 0.32; }
    100% { opacity: 0.18; }
  }

  @keyframes evo-node-pulse {
    0% { transform: scale(0.92); opacity: 0.44; }
    35% { transform: scale(1.28); opacity: 1; }
    100% { transform: scale(0.96); opacity: 0.56; }
  }

  @keyframes zerg-creep {
    0% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.04); opacity: 0.95; }
    100% { transform: scale(1.01); opacity: 0.72; }
  }

  @keyframes terran-scan {
    0% { background-position: 0% 0%; }
    100% { background-position: 0% 220%; }
  }

  @keyframes mech-rotate {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.06); }
    100% { transform: rotate(360deg) scale(1); }
