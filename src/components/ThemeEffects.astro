    const drawThreeBody = (scene, phase, animate) => {
      const background = context.createLinearGradient(0, 0, 0, height);
      background.addColorStop(0, '#120404');
      background.addColorStop(1, '#010101');
      context.fillStyle = background;
      context.fillRect(0, 0, width, height);

      scene.stars.forEach((star) => {
        context.beginPath();
        context.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
        context.fillStyle = `rgba(255, 255, 255, ${star.alpha})`;
        context.fill();
      });

      const bodies = [
        {
          x: width * 0.5 + Math.cos(phase * 0.8) * width * 0.16,
          y: height * 0.5 + Math.sin(phase * 1.05) * height * 0.1,
          radius: 11,
          color: '255, 121, 58',
