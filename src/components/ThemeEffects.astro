      context.lineTo(bodies[1].x, bodies[1].y);
      context.lineTo(bodies[2].x, bodies[2].y);
      context.closePath();
      context.strokeStyle = 'rgba(255, 140, 84, 0.35)';
      context.stroke();

      const barycenter = bodies.reduce(
        (accumulator, body) => ({
          x: accumulator.x + body.x / bodies.length,
          y: accumulator.y + body.y / bodies.length,
        }),
        { x: 0, y: 0 },
