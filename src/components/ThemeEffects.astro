        scene.particles.forEach((particle) => {
          particle.x += particle.vx;
          particle.y += particle.vy;

          if (particle.x < -20) particle.x = width + 20;
          if (particle.x > width + 20) particle.x = -20;
          if (particle.y < -20) particle.y = height + 20;
          if (particle.y > height + 20) particle.y = -20;
        });
      }

      for (let i = 0; i < scene.particles.length; i += 1) {
        for (let j = i + 1; j < scene.particles.length; j += 1) {
          const a = scene.particles[i];
          const b = scene.particles[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          if (distance > 260) continue;
          const alpha = (1 - distance / 260) * 0.26;
          context.beginPath();
          context.moveTo(a.x, a.y);
          context.lineTo(b.x, b.y);
          context.strokeStyle = `rgba(126, 220, 255, ${alpha})`;
          context.lineWidth = distance < 120 ? 1.3 : 1;
          context.stroke();
