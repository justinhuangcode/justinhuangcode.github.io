  <div class="theme-scene-base"></div>
  <div class="theme-scene-pattern"></div>
  <canvas class="theme-scene-canvas theme-scene-matrix-canvas" aria-hidden="true"></canvas>
  <canvas class="theme-scene-canvas theme-scene-blackmirror-canvas" aria-hidden="true"></canvas>
  <canvas class="theme-scene-canvas theme-scene-protoss-canvas" aria-hidden="true"></canvas>
