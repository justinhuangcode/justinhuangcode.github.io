---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  class?: string;
}

const { image, alt, class: className } = Astro.props;
---

<Image
  src={image}
  alt={alt}
  widths={[640, 960, 1280]}
  sizes="(max-width: 640px) 640px, (max-width: 960px) 960px, 1280px"
  class:list={['w-full rounded-lg', className]}
  loading="eager"
  decoding="async"
/>
