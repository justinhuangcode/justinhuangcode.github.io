---
import '@/styles/fonts.css';
import '@/styles/global.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { createHash } from 'node:crypto';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ThemeEffects from '@/components/ThemeEffects.astro';
import Analytics from '@/components/Analytics.astro';
import Crisp from '@/components/Crisp.astro';
import LocaleBanner from '@/components/LocaleBanner.astro';
import WeChatShare from '@/components/WeChatShare.astro';
import { siteConfig } from '@/config/site';
import { CUSTOM_THEME_KEYS } from '@/lib/theme';
import {
  defaultLocale,
  getLocaleFromUrl,
  getMessages,
  htmlLangs,
  locales,
  stripLocalePrefix,
} from '@/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  canonicalUrl?: string;
  enableCrisp?: boolean;
  hideNavbar?: boolean;
  hideFooter?: boolean;
  hideLocaleBanner?: boolean;
  hideLocaleAlternates?: boolean;
  localeAlternates?: { hreflang: string; href: string }[];
  hideThemeEffects?: boolean;
  bodyClass?: string;
  mainClass?: string;
  article?: {
    publishedTime: string;
    author: string;
    tags?: string[];
  };
  alternateFormats?: { type: string; href: string; title: string }[];
}

interface ShareImage {
  url: string;
  width?: number;
  height?: number;
  type?: string;
  alt: string;
}

const locale = getLocaleFromUrl(Astro.url);
const allBannerMessages = Object.fromEntries(
  locales.map((l) => [l, getMessages(l).localeBanner])
);
const {
  title = siteConfig.title,
  description = siteConfig.description,
  image: imageProp,
  jsonLd,
  canonicalUrl: canonicalUrlOverride,
  enableCrisp = true,
  hideNavbar = false,
  hideFooter = false,
  hideLocaleBanner = false,
  hideLocaleAlternates = false,
  localeAlternates,
  hideThemeEffects = false,
  bodyClass = '',
  mainClass = '',
  article,
  alternateFormats,
} = Astro.props;

function createOgImageAlt(pageTitle: string): string {
  const suffixPatterns = [` | ${siteConfig.name}`, ` - ${siteConfig.name}`];
  const normalizedTitle = suffixPatterns.reduce(
    (current, suffix) => (current.endsWith(suffix) ? current.slice(0, -suffix.length) : current),
    pageTitle,
  );
  return normalizedTitle === siteConfig.name
    ? siteConfig.name
    : `${normalizedTitle} - ${siteConfig.name}`;
}

const ogImageAlt = createOgImageAlt(title);

function inferOgImageType(pathname: string): string | undefined {
  const normalizedPath = pathname.toLowerCase();
  if (normalizedPath.endsWith('.png')) return 'image/png';
  if (normalizedPath.endsWith('.jpg') || normalizedPath.endsWith('.jpeg')) return 'image/jpeg';
  if (normalizedPath.endsWith('.gif')) return 'image/gif';
  if (normalizedPath.endsWith('.webp')) return 'image/webp';
  return undefined;
}

function createOgVersionToken(parts: Array<string | undefined>) {
  return createHash('sha1')
    .update(parts.filter(Boolean).join('|'))
    .digest('hex')
    .slice(0, 10);
}

function getNumericDimension(value: unknown): number | undefined {
  if (typeof value === 'number') return value;
  if (typeof value === 'string' && value) return Number(value);
  return undefined;
}

function createVersionedUrl(sourceUrl: URL, versionParts: Array<string | undefined>) {
  const url = new URL(sourceUrl);
  url.searchParams.set('v', createOgVersionToken(versionParts));
  return url;
}

function createSquareOgPath(pathname: string): string | undefined {
  if (!pathname.startsWith('/og/') || !pathname.endsWith('.png')) return undefined;
  return pathname.replace('/og/', '/og-square/');
}

// Resolve share images: keep 1.91:1 primary, add square secondary when available
const imageSource = imageProp ?? siteConfig.ogImage;
const shareImages: ShareImage[] = [];

if (typeof imageSource === 'string') {
  const primarySourceUrl = imageSource.startsWith('http')
    ? new URL(imageSource)
    : new URL(imageSource, siteConfig.url);

  const primaryUrl = createVersionedUrl(primarySourceUrl, [
    title,
    description,
    article?.publishedTime,
    primarySourceUrl.pathname,
  ]);
  const primaryImage: ShareImage = {
    url: primaryUrl.href,
    type: inferOgImageType(primarySourceUrl.pathname),
    alt: ogImageAlt,
  };
  if (primarySourceUrl.pathname.startsWith('/og/') && primaryImage.type === 'image/png') {
    primaryImage.width = 1200;
    primaryImage.height = 630;
  }
  shareImages.push(primaryImage);

  const squarePath = createSquareOgPath(primarySourceUrl.pathname);
  if (squarePath) {
    const squareSourceUrl = new URL(squarePath, siteConfig.url);
    const squareUrl = createVersionedUrl(squareSourceUrl, [
      title,
      description,
      article?.publishedTime,
      squareSourceUrl.pathname,
    ]);
    shareImages.push({
      url: squareUrl.href,
      width: 1200,
      height: 1200,
      type: 'image/png',
      alt: ogImageAlt,
    });
  }
} else {
  const optimizedLandscape = await getImage({ src: imageSource, width: 1200, format: 'png' });
  const landscapeSourceUrl = new URL(optimizedLandscape.src, siteConfig.url);
  const landscapeUrl = createVersionedUrl(landscapeSourceUrl, [
    title,
    description,
    article?.publishedTime,
    landscapeSourceUrl.pathname,
  ]);
  const landscapeWidth = getNumericDimension(optimizedLandscape.attributes.width);
  const landscapeHeight = getNumericDimension(optimizedLandscape.attributes.height);

  shareImages.push({
    url: landscapeUrl.href,
    width: landscapeWidth,
    height: landscapeHeight,
    type: inferOgImageType(landscapeSourceUrl.pathname) ?? 'image/png',
    alt: ogImageAlt,
  });

  if (!(landscapeWidth === 1200 && landscapeHeight === 1200)) {
    const optimizedSquare = await getImage({
      src: imageSource,
      width: 1200,
      height: 1200,
      fit: 'cover',
      format: 'png',
    });
    const squareSourceUrl = new URL(optimizedSquare.src, siteConfig.url);
    const squareUrl = createVersionedUrl(squareSourceUrl, [
      title,
      description,
      article?.publishedTime,
      squareSourceUrl.pathname,
    ]);
    shareImages.push({
      url: squareUrl.href,
      width: getNumericDimension(optimizedSquare.attributes.width),
      height: getNumericDimension(optimizedSquare.attributes.height),
      type: inferOgImageType(squareSourceUrl.pathname) ?? 'image/png',
      alt: ogImageAlt,
    });
  }
}
const primaryShareImage = shareImages[0];
const wechatShareImage =
  shareImages.find((image) => image.width && image.height && image.width === image.height) ??
  primaryShareImage;

// Canonical URL
const pathname = Astro.url.pathname;
const canonicalUrl = canonicalUrlOverride ?? new URL(pathname, siteConfig.url).href;

const cleanPath = stripLocalePrefix(pathname);
const defaultAlternateUrls = locales.map((l) => ({
  hreflang: htmlLangs[l],
  href: new URL(l === defaultLocale ? cleanPath : `/${l}${cleanPath}`, siteConfig.url).href,
}));
const alternateUrls = hideLocaleAlternates
  ? []
  : localeAlternates ?? defaultAlternateUrls;
const xDefaultAlternateUrl = hideLocaleAlternates
  ? undefined
  : localeAlternates
    ? alternateUrls.find(({ hreflang }) => hreflang === htmlLangs[defaultLocale])?.href ?? canonicalUrl
    : new URL(cleanPath, siteConfig.url).href;

---

<html
  lang={htmlLangs[locale]}
  class="no-transition"
  data-default-mode={siteConfig.ui.defaultMode}
  data-default-style={siteConfig.ui.defaultStyle}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    {!hideLocaleAlternates && xDefaultAlternateUrl && (
      <link rel="alternate" hreflang="x-default" href={xDefaultAlternateUrl} />
    )}
    {alternateFormats?.map(({ type, href, title: t }) => (
      <link rel="alternate" type={type} href={href} title={t} />
    ))}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {shareImages.map((image) => (
      <Fragment>
        <meta property="og:image" content={image.url} />
        <meta property="og:image:secure_url" content={image.url} />
        {image.type && <meta property="og:image:type" content={image.type} />}
        {image.width && <meta property="og:image:width" content={String(image.width)} />}
        {image.height && <meta property="og:image:height" content={String(image.height)} />}
        <meta property="og:image:alt" content={image.alt} />
      </Fragment>
    ))}
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    {article && (
      <Fragment>
        <meta property="article:published_time" content={article.publishedTime} />
        <meta property="article:author" content={article.author} />
        {article.tags?.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </Fragment>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={primaryShareImage.url} />
    <meta name="twitter:image:alt" content={primaryShareImage.alt} />
    {jsonLd && Array.isArray(jsonLd) ? (
      jsonLd.map((item) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    ) : jsonLd ? (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    ) : null}
    <WeChatShare
      title={title}
      description={description}
      link={canonicalUrl}
      imgUrl={wechatShareImage.url}
    />
    <Analytics />
    {enableCrisp && <Crisp locale={locale} />}
    <script
      is:inline
      define:vars={{
        defaultMode: siteConfig.ui.defaultMode,
        defaultStyle: siteConfig.ui.defaultStyle,
        customThemeKeys: CUSTOM_THEME_KEYS,
      }}
    >
      (function () {
        try {
          var storedMode = localStorage.getItem('color-mode');
          var storedStyle = localStorage.getItem('theme-style');
          var legacyTheme = localStorage.getItem('theme');
          var mode =
            storedMode === 'light' || storedMode === 'dark' || storedMode === 'system'
              ? storedMode
              : defaultMode;
          var style =
            storedStyle && (storedStyle === 'default' || customThemeKeys.indexOf(storedStyle) > -1)
              ? storedStyle
              : defaultStyle;

          if (!storedMode && !storedStyle && legacyTheme) {
            if (legacyTheme === 'light' || legacyTheme === 'dark' || legacyTheme === 'system') {
              mode = legacyTheme;
            } else if (customThemeKeys.indexOf(legacyTheme) > -1) {
              style = legacyTheme;
            }
          }

          var systemTheme = window.matchMedia('(prefers-color-scheme: dark)')
            .matches
            ? 'dark'
            : 'light';
          var resolved = mode === 'system' ? systemTheme : mode;
          var root = document.documentElement;

          root.classList.remove('light', 'dark');
          root.classList.add(style === 'default' ? resolved : style);
          root.dataset.mode = resolved;
          root.dataset.theme = style;
        } catch (e) {
          var fallbackMode = defaultMode === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : defaultMode;
          document.documentElement.classList.add(defaultStyle === 'default' ? fallbackMode : defaultStyle);
          document.documentElement.dataset.mode = fallbackMode;
          document.documentElement.dataset.theme = defaultStyle;
        }
      })();
    </script>
    <script is:inline>
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.documentElement.classList.remove('no-transition');
        });
      });
    </script>
    <script>
      import {
        THEME_CHANGE_EVENT,
        applyThemePreferences,
        getStoredThemePreferences,
        isColorMode,
        isThemeStyle,
        resolveColorMode,
        type ColorMode,
        type ThemeStyle,
      } from '@/lib/theme';

      const root = document.documentElement;
      const rawDefaultMode = root.dataset.defaultMode ?? '';
      const rawDefaultStyle = root.dataset.defaultStyle ?? '';
      const defaultMode: ColorMode = isColorMode(rawDefaultMode)
        ? rawDefaultMode
        : 'system';
      const defaultStyle: ThemeStyle = isThemeStyle(rawDefaultStyle)
        ? rawDefaultStyle
        : 'default';
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      const syncSystemTheme = () => {
        const preferences = getStoredThemePreferences(defaultMode, defaultStyle);
        if (preferences.mode !== 'system') return;

        applyThemePreferences(preferences);
        window.dispatchEvent(
          new CustomEvent(THEME_CHANGE_EVENT, {
            detail: {
              ...preferences,
              resolvedMode: resolveColorMode(preferences.mode),
            },
          }),
        );
      };

      if (!window.__aitherSystemThemeListenerBound) {
        window.__aitherSystemThemeListenerBound = true;
        mediaQuery.addEventListener('change', syncSystemTheme);
      }
    </script>
    <slot name="head" />
  </head>
  <body
    class:list={['font-body antialiased bg-background text-foreground', bodyClass]}
    style="font-weight:400"
  >
    {!hideLocaleBanner && (
      <LocaleBanner
        currentLocale={locale}
        currentPath={Astro.url.pathname}
        allMessages={allBannerMessages}
      />
    )}
    {!hideThemeEffects && <ThemeEffects />}
    <div class="flex min-h-screen flex-col relative z-[1]">
      {!hideNavbar && <Navbar locale={locale} />}
      <main class:list={['flex-1', mainClass]}>
        <slot />
      </main>
      {!hideFooter && <Footer locale={locale} />}
    </div>
  </body>
</html>
