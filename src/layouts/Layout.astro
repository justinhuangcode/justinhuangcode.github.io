---
import '@/styles/fonts.css';
import '@/styles/global.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import Analytics from '@/components/Analytics.astro';
import Crisp from '@/components/Crisp.astro';
import LocaleBanner from '@/components/react/LocaleBanner';
import { siteConfig } from '@/config/site';
import { getLocaleFromUrl, getMessages, locales } from '@/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  article?: {
    publishedTime: string;
    author: string;
    tags?: string[];
  };
  alternateFormats?: { type: string; href: string; title: string }[];
}

const locale = getLocaleFromUrl(Astro.url);
const m = getMessages(locale);
const allBannerMessages = Object.fromEntries(
  locales.map((l) => [l, getMessages(l).localeBanner])
);
const {
  title = siteConfig.title,
  description = siteConfig.description,
  image: imageProp,
  jsonLd,
  article,
  alternateFormats,
} = Astro.props;

// Resolve OG image: optimize ImageMetadata, pass through strings
const imageSource = imageProp ?? siteConfig.ogImage;
let ogImageUrl: string;
if (typeof imageSource === 'string') {
  ogImageUrl = imageSource.startsWith('http')
    ? imageSource
    : new URL(imageSource, siteConfig.url).href;
} else {
  const optimized = await getImage({ src: imageSource, width: 1200, format: 'webp' });
  ogImageUrl = new URL(optimized.src, siteConfig.url).href;
}

// Canonical URL
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, siteConfig.url).href;

// Hreflang: map locale codes to BCP 47 tags
const hreflangMap: Record<string, string> = {
  en: 'en', 'zh-hans': 'zh-Hans', 'zh-hant': 'zh-Hant',
  ko: 'ko', fr: 'fr', de: 'de', it: 'it',
  es: 'es', ru: 'ru', id: 'id', 'pt-br': 'pt-BR',
};

// Build the locale-independent path for hreflang alternates
const localePattern = locales.filter(l => l !== 'en').join('|');
const cleanPath = pathname.replace(new RegExp(`^\\/(${localePattern})`), '') || '/';
const alternateUrls = locales.map((l) => ({
  hreflang: hreflangMap[l],
  href: new URL(l === 'en' ? cleanPath : `/${l}${cleanPath}`, siteConfig.url).href,
}));

---

<html lang={locale} class="no-transition">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(cleanPath, siteConfig.url).href} />
    <link rel="search" type="application/opensearchdescription+xml" title={siteConfig.name} href="/opensearch.xml" />
    {alternateFormats?.map(({ type, href, title: t }) => (
      <link rel="alternate" type={type} href={href} title={t} />
    ))}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    {article && (
      <Fragment>
        <meta property="article:published_time" content={article.publishedTime} />
        <meta property="article:author" content={article.author} />
        {article.tags?.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </Fragment>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLd && Array.isArray(jsonLd) ? (
      jsonLd.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    ) : jsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    ) : null}
    <Analytics />
    <Crisp />
    <script is:inline define:vars={{ defaultMode: siteConfig.ui.defaultMode }}>
      (function () {
        try {
          var theme = localStorage.getItem('theme') || defaultMode;
          var systemTheme = window.matchMedia('(prefers-color-scheme: dark)')
            .matches
            ? 'dark'
            : 'light';
          var resolved = theme === 'system' ? systemTheme : theme;
          document.documentElement.classList.add(resolved);
        } catch (e) {
          document.documentElement.classList.add(defaultMode);
        }
      })();
    </script>
    <script is:inline define:vars={{ currentLocale: locale }}>
      (function () {
        // Auto-redirect if user previously selected a different locale
        var preferred = localStorage.getItem('preferred-locale');
        if (preferred && preferred !== currentLocale) {
          var path = window.location.pathname;
          var clean = path.replace(/^\/(en|zh-hans|zh-hant|ko|fr|de|it|es|ru|id|pt-br)/, '') || '/';
          var newPath = preferred === 'en' ? clean : '/' + preferred + clean;
          window.location.replace(newPath);
        }
      })();
    </script>
    <script is:inline>
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.documentElement.classList.remove('no-transition');
        });
      });
    </script>
  </head>
  <body
    class="font-body antialiased bg-background text-foreground"
    style="font-weight:400"
  >
    <LocaleBanner
      client:idle
      currentLocale={locale}
      currentPath={Astro.url.pathname}
      allMessages={allBannerMessages}
    />
    <div class="flex min-h-screen flex-col">
      <Navbar locale={locale} />
      <main class="flex-1">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>
