---
import '@/styles/fonts.css';
import '@/styles/global.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ThemeEffects from '@/components/ThemeEffects.astro';
import Analytics from '@/components/Analytics.astro';
import Crisp from '@/components/Crisp.astro';
import LocaleBanner from '@/components/LocaleBanner.astro';
import { siteConfig } from '@/config/site';
import { CUSTOM_THEME_KEYS } from '@/lib/theme';
import {
  getLocaleFromUrl,
  getMessages,
  htmlLangs,
  locales,
  stripLocalePrefix,
} from '@/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  enableCrisp?: boolean;
  article?: {
    publishedTime: string;
    author: string;
    tags?: string[];
  };
  alternateFormats?: { type: string; href: string; title: string }[];
}

const locale = getLocaleFromUrl(Astro.url);
const allBannerMessages = Object.fromEntries(
  locales.map((l) => [l, getMessages(l).localeBanner])
);
const {
  title = siteConfig.title,
  description = siteConfig.description,
  image: imageProp,
  jsonLd,
  enableCrisp = true,
  article,
  alternateFormats,
} = Astro.props;

// Resolve OG image: optimize ImageMetadata, pass through strings
const imageSource = imageProp ?? siteConfig.ogImage;
let ogImageUrl: string;
if (typeof imageSource === 'string') {
  ogImageUrl = imageSource.startsWith('http')
    ? imageSource
    : new URL(imageSource, siteConfig.url).href;
} else {
  const optimized = await getImage({ src: imageSource, width: 1200, format: 'webp' });
  ogImageUrl = new URL(optimized.src, siteConfig.url).href;
}

// Canonical URL
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, siteConfig.url).href;

// Hreflang: map locale codes to BCP 47 tags
const hreflangMap: Record<string, string> = {
  en: 'en', 'zh-hans': 'zh-Hans', 'zh-hant': 'zh-Hant',
  ko: 'ko', fr: 'fr', de: 'de', it: 'it',
  es: 'es', ru: 'ru', id: 'id', 'pt-br': 'pt-BR',
};

// Build the locale-independent path for hreflang alternates
const cleanPath = stripLocalePrefix(pathname);
const alternateUrls = locales.map((l) => ({
  hreflang: hreflangMap[l],
  href: new URL(l === 'en' ? cleanPath : `/${l}${cleanPath}`, siteConfig.url).href,
}));

---

<html
  lang={htmlLangs[locale]}
  class="no-transition"
  data-default-mode={siteConfig.ui.defaultMode}
  data-default-style={siteConfig.ui.defaultStyle}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(cleanPath, siteConfig.url).href} />
    {alternateFormats?.map(({ type, href, title: t }) => (
      <link rel="alternate" type={type} href={href} title={t} />
    ))}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    {article && (
      <Fragment>
        <meta property="article:published_time" content={article.publishedTime} />
        <meta property="article:author" content={article.author} />
        {article.tags?.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </Fragment>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLd && Array.isArray(jsonLd) ? (
      jsonLd.map((item) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    ) : jsonLd ? (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    ) : null}
    <Analytics />
    {enableCrisp && <Crisp locale={locale} />}
    <script
      is:inline
      define:vars={{
        defaultMode: siteConfig.ui.defaultMode,
        defaultStyle: siteConfig.ui.defaultStyle,
        customThemeKeys: CUSTOM_THEME_KEYS,
      }}
    >
      (function () {
        try {
          var storedMode = localStorage.getItem('color-mode');
          var storedStyle = localStorage.getItem('theme-style');
          var legacyTheme = localStorage.getItem('theme');
          var mode =
            storedMode === 'light' || storedMode === 'dark' || storedMode === 'system'
              ? storedMode
              : defaultMode;
          var style =
            storedStyle && (storedStyle === 'default' || customThemeKeys.indexOf(storedStyle) > -1)
              ? storedStyle
              : defaultStyle;

          if (!storedMode && !storedStyle && legacyTheme) {
            if (legacyTheme === 'light' || legacyTheme === 'dark' || legacyTheme === 'system') {
              mode = legacyTheme;
            } else if (customThemeKeys.indexOf(legacyTheme) > -1) {
              style = legacyTheme;
            }
          }

          var systemTheme = window.matchMedia('(prefers-color-scheme: dark)')
            .matches
            ? 'dark'
            : 'light';
          var resolved = mode === 'system' ? systemTheme : mode;
          var root = document.documentElement;

          root.classList.remove('light', 'dark');
          root.classList.add(style === 'default' ? resolved : style);
          root.dataset.mode = resolved;
          root.dataset.theme = style;
        } catch (e) {
          var fallbackMode = defaultMode === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : defaultMode;
          document.documentElement.classList.add(defaultStyle === 'default' ? fallbackMode : defaultStyle);
          document.documentElement.dataset.mode = fallbackMode;
          document.documentElement.dataset.theme = defaultStyle;
        }
      })();
    </script>
    <script is:inline>
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.documentElement.classList.remove('no-transition');
        });
      });
    </script>
    <script>
      import {
        THEME_CHANGE_EVENT,
        applyThemePreferences,
        getStoredThemePreferences,
        isColorMode,
        isThemeStyle,
        resolveColorMode,
        type ColorMode,
        type ThemeStyle,
      } from '@/lib/theme';

      const root = document.documentElement;
      const rawDefaultMode = root.dataset.defaultMode ?? '';
      const rawDefaultStyle = root.dataset.defaultStyle ?? '';
      const defaultMode: ColorMode = isColorMode(rawDefaultMode)
        ? rawDefaultMode
        : 'system';
      const defaultStyle: ThemeStyle = isThemeStyle(rawDefaultStyle)
        ? rawDefaultStyle
        : 'default';
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      const syncSystemTheme = () => {
        const preferences = getStoredThemePreferences(defaultMode, defaultStyle);
        if (preferences.mode !== 'system') return;

        applyThemePreferences(preferences);
        window.dispatchEvent(
          new CustomEvent(THEME_CHANGE_EVENT, {
            detail: {
              ...preferences,
              resolvedMode: resolveColorMode(preferences.mode),
            },
          }),
        );
      };

      mediaQuery.addEventListener('change', syncSystemTheme);
    </script>
  </head>
  <body
    class="font-body antialiased bg-background text-foreground"
    style="font-weight:400"
  >
    <LocaleBanner
      currentLocale={locale}
      currentPath={Astro.url.pathname}
      allMessages={allBannerMessages}
    />
    <ThemeEffects />
    <div class="flex min-h-screen flex-col relative z-[1]">
      <Navbar locale={locale} />
      <main class="flex-1">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>
