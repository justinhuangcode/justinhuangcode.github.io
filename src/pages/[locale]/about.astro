---
import AboutPage from '@/components/pages/AboutPage.astro';
import {
  nonDefaultLocales,
  type Locale,
} from '@/i18n';

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
---

<AboutPage locale={locale} />
