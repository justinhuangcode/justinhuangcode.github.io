---
import ForAgentsPage from '@/components/pages/ForAgentsPage.astro';
import {
  nonDefaultLocales,
  type Locale,
} from '@/i18n';

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
---

<ForAgentsPage locale={locale} />
