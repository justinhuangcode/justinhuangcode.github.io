---
import ContentSectionIndexPage from '@/components/pages/ContentSectionIndexPage.astro';
import { type ContentSection } from '@/config/site';
import { type Locale } from '@/i18n';
import {
  createLocalizedStaticPaths,
  createSectionIndexStaticPaths,
} from '@/lib/route-helpers';
import { getContentByLocale } from '@/lib/posts';

export async function getStaticPaths() {
  return createLocalizedStaticPaths((locale) => createSectionIndexStaticPaths(locale));
}

const { locale, section } = Astro.props as { locale: Locale; section: ContentSection };
const entries = await getContentByLocale(section.id, locale);
---

<ContentSectionIndexPage locale={locale} section={section} entries={entries} />
