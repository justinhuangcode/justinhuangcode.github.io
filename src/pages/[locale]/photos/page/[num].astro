---
import PhotosIndexPage from '@/components/pages/PhotosIndexPage.astro';
import { type Locale } from '@/i18n';
import { getPaginatedGallery, getGalleryPaginationStaticPaths } from '@/lib/gallery';
import { createLocalizedStaticPaths } from '@/lib/route-helpers';

export async function getStaticPaths() {
  return createLocalizedStaticPaths((locale) => getGalleryPaginationStaticPaths(locale));
}

const { locale } = Astro.props as { locale: Locale };
const currentPage = Number(Astro.params.num);
const { entries, categories, totalPages } = await getPaginatedGallery(locale, currentPage);
---

<PhotosIndexPage
  locale={locale}
  entries={entries}
  categories={categories}
  currentPage={currentPage}
  totalPages={totalPages}
/>
