---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import { type Locale } from '@/i18n';
import { createLocaleOnlyStaticPaths } from '@/lib/route-helpers';
import { getPaginatedPosts } from '@/lib/site-content';

export const getStaticPaths = createLocaleOnlyStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const { posts, totalPages, allPosts } = await getPaginatedPosts(locale, 1);
---

<BlogIndexPage
  locale={locale}
  currentPage={1}
  posts={posts}
  totalPages={totalPages}
  totalPostCount={allPosts.length}
/>
