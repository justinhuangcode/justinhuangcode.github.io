---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import {
  nonDefaultLocales,
  type Locale,
} from '@/i18n';
import { getPaginatedPosts } from '@/lib/site-content';

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
const { posts, totalPages } = await getPaginatedPosts(locale, 1);
---

<BlogIndexPage locale={locale} currentPage={1} posts={posts} totalPages={totalPages} />
