---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import {
  nonDefaultLocales,
  type Locale,
} from '@/i18n';
import {
  getPaginatedPosts,
  getPaginationStaticPaths,
} from '@/lib/site-content';

export async function getStaticPaths() {
  const paths: Array<{
    params: { locale: string; num: string };
    props: { locale: Locale };
  }> = [];
  for (const locale of nonDefaultLocales) {
    const localePaths = await getPaginationStaticPaths(locale);
    localePaths.forEach((path) => {
      paths.push({
        params: { locale, ...path.params },
        props: { locale },
      });
    });
  }
  return paths;
}

const { locale } = Astro.props as { locale: Locale };
const currentPage = Number(Astro.params.num);
const { posts, totalPages } = await getPaginatedPosts(locale, currentPage);
---

<BlogIndexPage locale={locale} currentPage={currentPage} posts={posts} totalPages={totalPages} />
