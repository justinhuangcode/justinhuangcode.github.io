---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import { type Locale } from '@/i18n';
import { createLocalizedStaticPaths } from '@/lib/route-helpers';
import { getPaginatedPosts, getPaginationStaticPaths } from '@/lib/site-content';

export async function getStaticPaths() {
  return createLocalizedStaticPaths((locale) => getPaginationStaticPaths(locale));
}

const { locale } = Astro.props as { locale: Locale };
const currentPage = Number(Astro.params.num);
const { posts, totalPages, allPosts } = await getPaginatedPosts(locale, currentPage);
---

<BlogIndexPage
  locale={locale}
  currentPage={currentPage}
  posts={posts}
  totalPages={totalPages}
  totalPostCount={allPosts.length}
/>
