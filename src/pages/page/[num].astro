---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import {
  getPaginatedPosts,
  getPaginationStaticPaths,
} from '@/lib/site-content';

export async function getStaticPaths() {
  return getPaginationStaticPaths('en');
}

const currentPage = Number(Astro.params.num);
const { posts, totalPages } = await getPaginatedPosts('en', currentPage);
---

<BlogIndexPage locale="en" currentPage={currentPage} posts={posts} totalPages={totalPages} />
