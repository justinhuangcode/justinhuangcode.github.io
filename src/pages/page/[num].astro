---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import {
  getPaginatedPosts,
  getPaginationStaticPaths,
} from '@/lib/site-content';
import { createRootStaticPaths, rootLocale } from '@/lib/route-helpers';

export const getStaticPaths = createRootStaticPaths(getPaginationStaticPaths);

const currentPage = Number(Astro.params.num);
const { posts, totalPages, allPosts } = await getPaginatedPosts(rootLocale, currentPage);
---

<BlogIndexPage
  locale={rootLocale}
  currentPage={currentPage}
  posts={posts}
  totalPages={totalPages}
  totalPostCount={allPosts.length}
/>
