---
import ContentSectionEntryPage from '@/components/pages/ContentSectionEntryPage.astro';
import type { CollectionKey } from 'astro:content';
import { type ContentSection } from '@/config/site';
import {
  createRootStaticPaths,
  createSectionEntryStaticPaths,
  rootLocale,
} from '@/lib/route-helpers';
import { type LocalizedEntry } from '@/lib/posts';

export const getStaticPaths = createRootStaticPaths(createSectionEntryStaticPaths);

const { section, entry, prevEntry, nextEntry } = Astro.props as {
  section: ContentSection;
  entry: LocalizedEntry<CollectionKey>;
  prevEntry: LocalizedEntry<CollectionKey> | null;
  nextEntry: LocalizedEntry<CollectionKey> | null;
};
const locale = rootLocale;
---

<ContentSectionEntryPage
  locale={locale}
  section={section}
  entry={entry}
  prevEntry={prevEntry}
  nextEntry={nextEntry}
/>
