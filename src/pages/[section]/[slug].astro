---
import { IconArrowLeft as ArrowLeft } from '@/components/icons';
import { IconArrowRight as ArrowRight } from '@/components/icons';
import BlogCoverImage from '@/components/BlogCoverImage.astro';
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import Prose from '@/components/Prose.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import Tag from '@/components/Tag.astro';
import CategoryPill from '@/components/CategoryPill.astro';
import Giscus from '@/components/Giscus.astro';
import type { CollectionKey } from 'astro:content';
import { render } from 'astro:content';
import { formatDate, wordCount, readingTime } from '@/lib/formatter';
import { siteConfig, type ContentSection } from '@/config/site';
import { getMessages } from '@/i18n';
import { getContentByLocale, getSlug, type LocalizedEntry } from '@/lib/posts';

export async function getStaticPaths() {
  const paths: Array<{
    params: { section: string; slug: string };
    props: {
      section: ContentSection;
      entry: LocalizedEntry<CollectionKey>;
      prevEntry: LocalizedEntry<CollectionKey> | null;
      nextEntry: LocalizedEntry<CollectionKey> | null;
    };
  }> = [];
  for (const s of siteConfig.sections) {
    const entries = await getContentByLocale(s.id, 'en');
    entries.forEach((entry, i) => {
      paths.push({
        params: { section: s.id, slug: getSlug(entry.id) },
        props: {
          section: s,
          entry,
          prevEntry: i < entries.length - 1 ? entries[i + 1] : null,
          nextEntry: i > 0 ? entries[i - 1] : null,
        },
      });
    });
  }
  return paths;
}

const { section, entry, prevEntry, nextEntry } = Astro.props as {
  section: ContentSection;
  entry: LocalizedEntry<CollectionKey>;
  prevEntry: LocalizedEntry<CollectionKey> | null;
  nextEntry: LocalizedEntry<CollectionKey> | null;
};
const { Content, headings } = await render(entry);
const m = getMessages('en');
const navLabels = m.nav as Record<string, string>;
const slug = getSlug(entry.id);
const entryUrl = `${siteConfig.url}/${section.id}/${slug}/`;
const sectionTitle = navLabels[section.labelKey] ?? section.labelKey;

const articleJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    datePublished: entry.data.date.toISOString(),
    author: { '@type': 'Person', name: siteConfig.author.name },
    publisher: { '@type': 'Organization', name: siteConfig.name },
    url: entryUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: siteConfig.name, item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: sectionTitle, item: `${siteConfig.url}/${section.id}/` },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: entryUrl },
    ],
  },
];
---

<Layout
  title={`${entry.data.title} | ${siteConfig.name}`}
  description={entry.data.description}
  image={entry.data.image ?? `/og/${slug}.png`}
  jsonLd={articleJsonLd}
  article={{
    publishedTime: entry.data.date.toISOString(),
    author: siteConfig.author.name,
    tags: entry.data.tags,
  }}
>
  <Container class="py-16 px-4">
    <div class="xl:grid xl:grid-cols-[1fr_220px] xl:gap-8">
      <article>
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <CategoryPill category={entry.data.category} locale="en" />
          {entry.data.tags?.map((tag) => <Tag tag={tag} locale="en" />)}
        </div>

        <h1 class="text-xl sm:text-2xl md:text-[31px] font-semibold mb-4 leading-[1.4] text-[var(--color-link)] break-words">{entry.data.title}</h1>

        <div class="mb-8 flex flex-wrap items-center gap-x-3 gap-y-1 text-muted-foreground/60 text-xs font-mono" title={m.blog.readingTimeTooltip.replace('{words}', String(wordCount(entry.body ?? ''))).replace('{minutes}', String(readingTime(entry.body ?? '')))}>
          <span>{formatDate(entry.data.date)}</span>
          <span>&middot;</span>
          <span>{wordCount(entry.body ?? '')} {m.blog.wordCount}</span>
          <span>&middot;</span>
          <span>{readingTime(entry.body ?? '')} {m.blog.minRead}</span>
        </div>

        {
          entry.data.description && (
            <p class="mt-4 text-muted-foreground text-lg leading-relaxed">
              {entry.data.description}
            </p>
          )
        }

        {entry.data.image && (
          <div class="mt-6">
            <BlogCoverImage image={entry.data.image} alt={entry.data.title} />
          </div>
        )}

        <div class="mt-6 pt-10 border-t border-border">
          <Prose>
            <Content />
          </Prose>
        </div>

        <div class="mt-10 flex items-center gap-4">
          <span class="flex-1 border-t border-border"></span>
          <span class="text-sm text-muted-foreground">{m.blog.endOfPost}{m.blog.thanksForReading}</span>
          <span class="flex-1 border-t border-border"></span>
        </div>

        <nav class="mt-6 flex flex-col sm:flex-row items-stretch justify-between gap-4">
          {prevEntry ? (
            <a
              href={`/${section.id}/${getSlug(prevEntry.id)}/`}
              class="group flex flex-col items-start text-sm hover:text-foreground sm:max-w-[45%] py-2"
            >
              <span class="inline-flex items-center gap-1 text-muted-foreground group-hover:text-foreground">
                <ArrowLeft className="size-3.5" />
                {m.blog.prevPost}
              </span>
              <span class="mt-1 text-[var(--color-link)] group-hover:text-[var(--color-link-hover)]">{prevEntry.data.title}</span>
            </a>
          ) : <span />}
          {nextEntry ? (
            <a
              href={`/${section.id}/${getSlug(nextEntry.id)}/`}
              class="group flex flex-col items-start sm:items-end text-sm hover:text-foreground sm:max-w-[45%] sm:ml-auto py-2"
            >
              <span class="inline-flex items-center gap-1 text-muted-foreground group-hover:text-foreground">
                {m.blog.nextPost}
                <ArrowRight className="size-3.5" />
              </span>
              <span class="mt-1 text-[var(--color-link)] group-hover:text-[var(--color-link-hover)]">{nextEntry.data.title}</span>
            </a>
          ) : <span />}
        </nav>

        <Giscus locale="en" />
      </article>
      <TableOfContents headings={headings} label={m.blog.onThisPage} />
    </div>
  </Container>
</Layout>
