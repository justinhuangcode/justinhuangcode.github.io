---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import { getMessages } from '@/i18n';

const m = getMessages('en');
---

<Layout title="404 — Not Found">
  <Container class="py-16 px-4">
    <div class="mx-auto max-w-md text-center py-24">
      <h1 class="text-6xl font-bold tracking-tight">{m.notFound.title}</h1>
      <p class="mt-4 text-lg text-muted-foreground">
        {m.notFound.description}
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center rounded-lg border border-border px-4 py-2 text-sm font-medium hover:bg-muted"
      >
        {m.notFound.backHome}
      </a>
    </div>
  </Container>
</Layout>
