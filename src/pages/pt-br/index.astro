---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import BlogCard from '@/components/BlogCard.astro';
import BlogPagination from '@/components/BlogPagination.astro';
import { siteConfig } from '@/config/site';
import { getPostsByLocale, getSlug } from '@/lib/posts';

const pageSize = siteConfig.blog.paginationSize;
const allPosts = await getPostsByLocale('pt-br');
const totalPages = Math.ceil(allPosts.length / pageSize);
const currentPage = 1;
const posts = allPosts.slice(0, pageSize);
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  description: siteConfig.description,
  url: `${siteConfig.url}/pt-br`,
  inLanguage: 'pt-BR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteConfig.url}/pt-br/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<Layout jsonLd={websiteJsonLd}>
  <Container class="px-4">
    <div class="mt-8">
      <BlogGrid>
        {
          posts.map((post) => (
            <BlogCard
              slug={getSlug(post.id)}
              title={post.data.title}
              date={post.data.date}
              locale="pt-BR"
              basePath="/pt-br"
              pinned={post.data.pinned}
            />
          ))
        }
      </BlogGrid>
    </div>
    <BlogPagination
      currentPage={currentPage}
      totalPages={totalPages}
      basePath="/pt-br"
    />
  </Container>
</Layout>
