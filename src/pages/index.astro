---
import BlogIndexPage from '@/components/pages/BlogIndexPage.astro';
import { getPaginatedPosts } from '@/lib/site-content';
import { rootLocale } from '@/lib/route-helpers';

const { posts, totalPages, allPosts } = await getPaginatedPosts(rootLocale, 1);
---

<BlogIndexPage
  locale={rootLocale}
  currentPage={1}
  posts={posts}
  totalPages={totalPages}
  totalPostCount={allPosts.length}
/>
