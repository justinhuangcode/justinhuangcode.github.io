{
  "name": "astro-theme-aither",
  "type": "module",
  "version": "2026.04.08",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "predev": "pnpm dev:directory-search",
    "dev": "astro dev",
    "dev:directory-search": "node ./scripts/build-directory-pagefind.mjs --output public/pagefind",
    "check:content": "node scripts/check-post-coverage.mjs && node scripts/check-post-math-markup.mjs",
    "check:agent": "node scripts/smoke-agent-protocol.mjs",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "build": "astro build && pnpm build:directory-search",
    "build:directory-search": "node ./scripts/build-directory-pagefind.mjs --output dist/pagefind",
    "preview": "astro preview",
    "upgrade:diff": "node scripts/release-diff.mjs",
    "validate": "pnpm check:content && pnpm check && pnpm typecheck && pnpm build && pnpm check:agent",
    "astro": "astro"
  },
  "dependencies": {
    "@aither/astro": "workspace:^2026.4.8",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/bricolage-grotesque": "^5.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^6.0.4",
    "katex": "^0.16.40",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "satori": "^0.25.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@resvg/resvg-js",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@astrojs/check": "^0.9.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "astro-expressive-code": "^0.41.7",
    "pagefind": "^1.4.0",
    "typescript": "^5.8.3"
  }
}
